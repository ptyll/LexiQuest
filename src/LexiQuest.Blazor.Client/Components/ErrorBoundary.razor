@using Microsoft.Extensions.Localization
@using LexiQuest.Blazor.Services
@inherits Microsoft.AspNetCore.Components.ErrorBoundaryBase
@inject IStringLocalizer<ErrorBoundary> L
@inject IErrorLoggingService ErrorLogging

@if (CurrentException is not null)
{
    <div class="error-boundary" data-testid="global-error-boundary" role="alert">
        <div class="error-boundary-panel">
            <h2 class="error-boundary-title">@L["Error_Title"]</h2>
            <p class="error-boundary-message">@L["Error_Description"]</p>
            <button type="button" class="tm-btn tm-btn-primary" data-testid="global-error-boundary-retry" @onclick="Recover">
                @L["Error_TryAgain"]
            </button>
        </div>
    </div>
}
else
{
    @ChildContent
}

@code {
    protected override async Task OnErrorAsync(Exception exception)
    {
        await ErrorLogging.LogErrorAsync(
            exception.Message,
            exception.StackTrace,
            nameof(ErrorBoundary),
            null);
    }

    public new void Recover()
    {
        base.Recover();
    }
}
