@using LexiQuest.Shared.DTOs.Game
@inject IStringLocalizer<LevelUpModal> L

@if (IsVisible && XpEvent?.LeveledUp == true)
{
    <div class="levelup-modal-overlay" data-testid="level-up-modal">
        <div class="levelup-modal" role="dialog" aria-modal="true" aria-labelledby="levelup-title">
            <h2 id="levelup-title" class="levelup-title">@L["Title"]</h2>
            
            <div class="levelup-level">
                @L["NewLevel", XpEvent.NewLevel]
            </div>
            
            @if (XpEvent.Unlocks?.Any() == true)
            {
                <div class="levelup-unlocks">
                    <h3>@L["Unlocks.Title"]</h3>
                    @foreach (var unlock in XpEvent.Unlocks)
                    {
                        <div class="unlock-item">
                            <span class="unlock-name">@GetUnlockName(unlock)</span>
                            <span class="unlock-description">@GetUnlockDescription(unlock)</span>
                        </div>
                    }
                </div>
            }
            
            <button type="button" class="levelup-continue-btn" data-testid="level-up-continue" @onclick="OnContinue">
                @L["Continue"]
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public XPGainedEvent? XpEvent { get; set; }
    
    [Parameter]
    public bool IsVisible { get; set; }
    
    [Parameter]
    public EventCallback OnContinue { get; set; }

    private string GetUnlockName(UnlockableReward unlock)
    {
        var localized = L[$"Unlock.{unlock.Type}.{unlock.Name}.Name"];
        return localized is null || localized.ResourceNotFound
            ? unlock.Name
            : localized.Value;
    }

    private string GetUnlockDescription(UnlockableReward unlock)
    {
        var localized = L[$"Unlock.{unlock.Type}.{unlock.Name}.Description"];
        return localized is null || localized.ResourceNotFound
            ? unlock.Description
            : localized.Value;
    }
}
