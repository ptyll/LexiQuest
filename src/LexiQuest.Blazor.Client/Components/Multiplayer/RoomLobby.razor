@inject IStringLocalizer<Pages.Multiplayer> Localizer
@inject IJSRuntime JSRuntime

<div class="room-lobby" data-testid="private-room-lobby" role="region" aria-label="@Localizer["Room_Lobby_Title"]">
    @if (IsExpired)
    {
        <div class="expired-state">
            <TmAlert Severity="AlertSeverity.Warning" Class="expired-message">
                @Localizer["Room_Expired"]
            </TmAlert>
            <TmButton Variant="ButtonVariant.Primary" OnClick="OnLeave">
                @Localizer["Button_Cancel"]
            </TmButton>
        </div>
    }
    else if (RoomStatus != null)
    {
        <div class="lobby-header">
            <h2 class="lobby-title">@Localizer["Room_Lobby_Title"]</h2>
            
            @if (IsHost && !HasOpponent)
            {
                <div class="room-code-section">
                    <span class="code-label">@Localizer["Room_Code_Label"]</span>
                    <div class="room-code-display">
                        <code class="room-code" data-testid="private-room-code">@RoomStatus.RoomCode</code>
                        <button class="copy-code-button tm-btn" data-testid="private-room-copy-code" @onclick="OnCopyCode" aria-label="@Localizer["Room_Code_Copy"]">
                            <TmIcon Name="copy" Size="IconSize.Sm" />
                        </button>
                    </div>
                    <p class="share-text">@string.Format(Localizer["Room_Code_ShareText"], RoomStatus.RoomCode)</p>
                    <div class="expiry-meter" aria-hidden="true">
                        <span style="@($"width: {GetExpiryProgress()}%")"></span>
                    </div>
                </div>
            }
        </div>

        <div class="players-section">
            @foreach (var player in RoomStatus.Players)
            {
                <div class="player-card @(player.IsReady ? "ready" : "")" data-testid="private-room-player">
                    <TmAvatar 
                        Name="@player.Username" 
                        Src="@player.Avatar" 
                        Size="AvatarSize.Xl" />
                    <div class="player-info">
                        <span class="player-name" data-testid="private-room-player-name">@player.Username</span>
                        @if (player.IsHost)
                        {
                            <TmBadge Variant="BadgeVariant.Primary" Size="BadgeSize.Sm">
                                @Localizer["Room_Player_Host"]
                            </TmBadge>
                        }
                    </div>
                    <div class="ready-status">
                        @if (player.IsReady)
                        {
                            <TmBadge Variant="BadgeVariant.Success" Size="BadgeSize.Md">
                                @Localizer["Room_Lobby_Ready"]
                            </TmBadge>
                        }
                        else
                        {
                            <TmBadge Variant="BadgeVariant.Warning" Size="BadgeSize.Md">
                                @Localizer["Room_Lobby_NotReady"]
                            </TmBadge>
                        }
                    </div>
                </div>
            }

            @if (!HasOpponent)
            {
                <div class="player-card placeholder">
                    <TmSpinner Size="SpinnerSize.Lg" />
                    <span class="waiting-message">@Localizer["Room_Lobby_WaitingForOpponent"]</span>
                </div>
            }
        </div>

        <div class="settings-summary">
            <h4>@Localizer["Room_Settings_Title"]</h4>
            <div class="settings-grid">
                <div class="setting">
                    <span class="setting-label">@Localizer["Room_Settings_WordCount"]</span>
                    <span class="setting-value" data-testid="private-room-settings-word-count">@RoomStatus.Settings.WordCount</span>
                </div>
                <div class="setting">
                    <span class="setting-label">@Localizer["Room_Settings_TimeLimit"]</span>
                    <span class="setting-value" data-testid="private-room-settings-time-limit">@string.Format(Localizer["Room_Settings_Minutes"], RoomStatus.Settings.TimeLimitMinutes)</span>
                </div>
                <div class="setting">
                    <span class="setting-label">@Localizer["Room_Settings_Difficulty"]</span>
                    <span class="setting-value" data-testid="private-room-settings-difficulty">@FormatDifficulty(RoomStatus.Settings.Difficulty)</span>
                </div>
                <div class="setting">
                    <span class="setting-label">@Localizer["Room_Settings_BestOf"]</span>
                    <span class="setting-value" data-testid="private-room-settings-best-of">@FormatBestOf(RoomStatus.Settings.BestOf)</span>
                </div>
            </div>
        </div>

        @if (RoomStatus.BothReady || CountdownSeconds > 0)
        {
            <div class="countdown-section">
                <p class="countdown-text">@Localizer["Room_Lobby_BothReady"]</p>
                <div class="countdown" data-testid="private-room-countdown">@CountdownSeconds</div>
            </div>
        }
        else if (HasOpponent)
        {
            <div class="ready-section">
                @if (IsReady)
                {
                    <TmButton 
                        Variant="ButtonVariant.Outline" 
                        Size="ButtonSize.Lg"
                        Class="ready-button"
                        AdditionalAttributes="@TestId("private-room-cancel-ready")"
                        OnClick="OnCancelReady">
                        @Localizer["Room_Lobby_CancelReadyButton"]
                    </TmButton>
                }
                else
                {
                    <TmButton 
                        Variant="ButtonVariant.Primary" 
                        Size="ButtonSize.Lg"
                        Class="ready-button"
                        AdditionalAttributes="@TestId("private-room-ready")"
                        OnClick="OnSetReady">
                        @Localizer["Room_Lobby_ReadyButton"]
                    </TmButton>
                }
            </div>
        }

        @if (HasOpponent)
        {
            <div class="chat-section" data-testid="private-room-chat-section">
                @if (!string.IsNullOrWhiteSpace(ChatErrorMessage))
                {
                    <TmAlert Severity="AlertSeverity.Warning" Class="chat-error" AdditionalAttributes="@TestId("private-room-chat-error")">
                        @ChatErrorMessage
                    </TmAlert>
                }
                <div class="chat-messages" @ref="_chatMessagesRef">
                    @foreach (var message in ChatMessages)
                    {
                        <div class="chat-message" data-testid="private-room-chat-message">
                            <TmAvatar Name="@message.SenderUsername" Size="AvatarSize.Xs" />
                            <div class="message-content">
                                <span class="message-sender">@message.SenderUsername</span>
                                <span class="message-text" data-testid="private-room-chat-message-text">@message.Message</span>
                                <span class="message-time">@message.SentAt.ToString("HH:mm")</span>
                            </div>
                        </div>
                    }
                </div>
                <div class="chat-input-section">
                    <input type="text"
                        value="@_currentMessage"
                        @oninput="HandleChatInput"
                        placeholder="@Localizer["Room_Lobby_Chat_Placeholder"]"
                        maxlength="200"
                        class="chat-input tm-input"
                        data-testid="private-room-chat-input"
                        @onkeyup="HandleChatKeyUp" />
                    <TmButton 
                        Variant="ButtonVariant.Primary" 
                        Size="ButtonSize.Sm"
                        Class="chat-send-button"
                        AdditionalAttributes="@TestId("private-room-chat-send")"
                        OnClick="SendMessage"
                        Disabled="string.IsNullOrWhiteSpace(_currentMessage)">
                        @Localizer["Room_Lobby_Chat_Send"]
                    </TmButton>
                </div>
            </div>
        }

        <div class="lobby-footer">
            <TmButton 
                Variant="ButtonVariant.Outline" 
                AdditionalAttributes="@TestId("private-room-leave")"
                OnClick="OnLeave">
                @Localizer["Button_Cancel"]
            </TmButton>
        </div>
    }
</div>

@code {
    [Parameter] public RoomStatusDto? RoomStatus { get; set; }
    [Parameter] public bool IsHost { get; set; }
    [Parameter] public bool IsReady { get; set; }
    [Parameter] public bool IsExpired { get; set; }
    [Parameter] public int CountdownSeconds { get; set; }
    [Parameter] public List<LobbyMessageDto> ChatMessages { get; set; } = new();
    [Parameter] public string? ChatErrorMessage { get; set; }
    [Parameter] public EventCallback OnSetReady { get; set; }
    [Parameter] public EventCallback OnCancelReady { get; set; }
    [Parameter] public EventCallback OnLeave { get; set; }
    [Parameter] public EventCallback<string> OnSendMessage { get; set; }
    [Parameter] public EventCallback OnCopyCode { get; set; }

    private ElementReference _chatMessagesRef;
    private string _currentMessage = "";

    private bool HasOpponent => RoomStatus?.Players.Count > 1;

    private static Dictionary<string, object> TestId(string value) =>
        new() { ["data-testid"] = value };

    private string FormatBestOf(int bestOf) =>
        bestOf switch
        {
            1 => Localizer["Room_Settings_BestOfSingle"].Value,
            3 => string.Format(Localizer["Room_Settings_BestOfSeries"], bestOf),
            _ => string.Format(Localizer["Room_Settings_BestOfSeriesMany"], bestOf)
        };

    private string FormatDifficulty(DifficultyLevel difficulty) => difficulty switch
    {
        DifficultyLevel.Beginner => Localizer["Difficulty_Beginner"].Value,
        DifficultyLevel.Intermediate => Localizer["Difficulty_Intermediate"].Value,
        DifficultyLevel.Advanced => Localizer["Difficulty_Advanced"].Value,
        DifficultyLevel.Expert => Localizer["Difficulty_Expert"].Value,
        _ => difficulty.ToString()
    };

    private int GetExpiryProgress()
    {
        if (RoomStatus == null) return 0;
        var totalMinutes = 5;
        var remaining = (RoomStatus.ExpiresAt - DateTime.UtcNow).TotalMinutes;
        var progress = (int)((remaining / totalMinutes) * 100);
        return Math.Clamp(progress, 0, 100);
    }

    private void HandleChatInput(ChangeEventArgs e)
    {
        _currentMessage = e.Value?.ToString() ?? "";
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_currentMessage)) return;
        
        await OnSendMessage.InvokeAsync(_currentMessage);
        _currentMessage = "";
        await ScrollToBottom();
    }

    private async Task HandleChatKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_currentMessage))
        {
            await SendMessage();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("scrollToBottom", _chatMessagesRef);
        }
        catch
        {
            // JS interop may not be available in test/SSR context
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ChatMessages.Count > 0)
        {
            await ScrollToBottom();
        }
    }
}
