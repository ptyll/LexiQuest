@using LexiQuest.Shared.DTOs.Shop
@inject IStringLocalizer<ShopItemCard> L

<div class="@GetCardClass()" data-testid="@GetCardTestId()">
<TmCard Variant="CardVariant.Default" Class="shop-item-card-surface">
    <div class="shop-item-card" data-testid="shop-item-card">
        @* Rarity border indicator *@
        <div class="rarity-border" style="border-color: @Item.RarityColor"></div>
        
        @* Premium lock overlay *@
        @if (Item.IsPremiumOnly && !IsOwned)
        {
            <div class="premium-overlay" data-testid="shop-premium-badge">
                <TmBadge Variant="BadgeVariant.Warning" Icon="@IconNames.Lock">
                    @L["Item_PremiumOnly"]
                </TmBadge>
            </div>
        }
        
        @* Item image *@
        <div class="item-image-container">
            <img src="@Item.ImageUrl" alt="@Item.Name" class="item-image" />
            @if (IsOwned)
            {
                <div class="owned-badge" data-testid="shop-owned-badge">
                    <TmBadge Variant="BadgeVariant.Success" Icon="@IconNames.Check">
                        @L["Item_Owned"]
                    </TmBadge>
                </div>
            }
        </div>
        
        @* Item details *@
        <div class="item-details">
            <h4 class="item-name">@Item.Name</h4>
            <p class="item-description">@Item.Description</p>
            
            <div class="item-meta">
                <div data-testid="shop-rarity-badge">
                    <TmBadge Variant="GetRarityBadgeVariant()">
                        @GetRarityLabel()
                    </TmBadge>
                </div>
                
                @if (Item.IsLimited)
                {
                    <TmBadge Variant="BadgeVariant.Warning" Icon="@IconNames.Clock">
                        @L["Label_Limited"]
                    </TmBadge>
                }
            </div>
        </div>
        
        @* Action button *@
        <div class="item-actions">
            @if (IsOwned)
            {
                @if (IsEquipped)
                {
                    <div data-testid="shop-equipped">
                        <TmButton Variant="ButtonVariant.Secondary" 
                                  Icon="@IconNames.Check"
                                  Disabled="true"
                                  Block="true">
                            @L["Button_Equipped"]
                        </TmButton>
                    </div>
                }
                else
                {
                    <div data-testid="shop-equip">
                        <TmButton Variant="ButtonVariant.Primary" 
                                  Icon="@IconNames.Star"
                                  OnClick="OnEquip"
                                  Block="true">
                            @L["Button_Equip"]
                        </TmButton>
                    </div>
                }
            }
            else
            {
                <div data-testid="shop-buy">
                    <TmButton Variant="ButtonVariant.Primary" 
                              Icon="@IconNames.Plus"
                              OnClick="OnPurchase"
                              Disabled="!Item.IsAvailable || (Item.IsPremiumOnly && !IsPremium)"
                              Block="true">
                            @Item.Price 🪙
                    </TmButton>
                </div>
            }
        </div>
    </div>
</TmCard>
</div>

@code {
    [Parameter]
    public ShopItemDto Item { get; set; } = default!;
    
    [Parameter]
    public bool IsOwned { get; set; }
    
    [Parameter]
    public bool IsEquipped { get; set; }
    
    [Parameter]
    public bool IsPremium { get; set; }
    
    [Parameter]
    public EventCallback OnPurchase { get; set; }
    
    [Parameter]
    public EventCallback OnEquip { get; set; }

    private string GetCardClass()
    {
        var classes = "shop-item-card-wrapper";
        if (Item.IsPremiumOnly && !IsOwned)
            classes += " premium-locked";
        if (IsEquipped)
            classes += " equipped";
        return classes;
    }

    private string GetCardTestId()
    {
        return $"shop-item-card-{CreateSlug(Item.Name)}";
    }

    private string GetRarityLabel()
    {
        var localized = L[$"Rarity_{Item.Rarity}"];
        return localized is { ResourceNotFound: false } && !string.IsNullOrWhiteSpace(localized.Value)
            ? localized.Value
            : Item.Rarity;
    }

    private BadgeVariant GetRarityBadgeVariant()
    {
        return Item.Rarity switch
        {
            "Legendary" => BadgeVariant.Warning,
            "Epic" => BadgeVariant.Info,
            "Rare" => BadgeVariant.Primary,
            _ => BadgeVariant.Default
        };
    }

    private static string CreateSlug(string value)
    {
        return value
            .ToLowerInvariant()
            .Replace("á", "a", StringComparison.Ordinal)
            .Replace("č", "c", StringComparison.Ordinal)
            .Replace("ď", "d", StringComparison.Ordinal)
            .Replace("é", "e", StringComparison.Ordinal)
            .Replace("ě", "e", StringComparison.Ordinal)
            .Replace("í", "i", StringComparison.Ordinal)
            .Replace("ň", "n", StringComparison.Ordinal)
            .Replace("ó", "o", StringComparison.Ordinal)
            .Replace("ř", "r", StringComparison.Ordinal)
            .Replace("š", "s", StringComparison.Ordinal)
            .Replace("ť", "t", StringComparison.Ordinal)
            .Replace("ú", "u", StringComparison.Ordinal)
            .Replace("ů", "u", StringComparison.Ordinal)
            .Replace("ý", "y", StringComparison.Ordinal)
            .Replace("ž", "z", StringComparison.Ordinal)
            .Replace(" ", "-", StringComparison.Ordinal);
    }
}
