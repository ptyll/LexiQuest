@using Microsoft.Extensions.Localization
@inject IStringLocalizer<GuestLimitReached> L

<div class="guest-limit-reached" data-testid="guest-limit-reached">
    <div class="limit-card">
        <div class="limit-icon">
            <TmIcon Name="@IconNames.Clock" Class="icon-clock" />
        </div>
        <h2 class="limit-title">@L["Title"]</h2>
        <p class="limit-description">@L["Description"]</p>
        <div class="limit-actions">
            <div data-testid="btn-register">
                <button class="guest-limit-button guest-limit-button-primary" type="button" @onclick="OnRegister">
                    @L["Register"]
                </button>
            </div>
            <div data-testid="btn-back">
                <button class="guest-limit-button guest-limit-button-ghost" type="button" @onclick="OnBack">
                    @L["Back"]
                </button>
            </div>
        </div>
        <div class="limit-login">
            <span>@L["HaveAccount"]</span>
            <div data-testid="btn-login">
                <button class="guest-limit-link" type="button" @onclick="OnLogin">
                    @L["Login"]
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnRegister { get; set; }
    [Parameter] public EventCallback OnLogin { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
}
