@page "/ai-challenge"
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Game
@using LexiQuest.Shared.Enums
@inject IAIChallengeClient AIChallengeClient
@inject IGameService GameService
@inject IStringLocalizer<AIChallenge> L
@inject NavigationManager Navigation

<div class="ai-challenge-page" data-testid="ai-challenge-page">
    <div class="page-header">
        <h1>@L["Page.Title"]</h1>
        <p>@L["Page.Subtitle"]</p>
    </div>

    @if (isLoading)
    {
        <div class="loading-state" data-testid="ai-challenge-loading">
            <TmSkeleton Type="Rectangle" Height="200px" />
            <TmSkeleton Type="Rectangle" Height="120px" />
            <TmSkeleton Type="Rectangle" Height="120px" />
        </div>
    }
    else if (errorMessage is not null)
    {
        <TmAlert Severity="AlertSeverity.Error" data-testid="ai-challenge-error">@errorMessage</TmAlert>
    }
    else
    {
        @if (analysis is not null)
        {
            <section class="analysis-section" data-testid="ai-analysis">
                <h2>@L["Analysis.Title"]</h2>

                <div class="analysis-grid">
                    <div class="analysis-card" data-testid="ai-weak-letters">
                        <h3>@L["Analysis.WeakLetters"]</h3>
                        @if (analysis.WeakLetters.Count == 0)
                        {
                            <p class="empty-hint" data-testid="ai-weak-letters-empty">@L["Analysis.WeakLetters.Empty"]</p>
                        }
                        else
                        {
                            <div class="weak-letters-list">
                                @foreach (var letter in analysis.WeakLetters)
                                {
                                    <div class="weak-letter-item" data-testid="ai-weak-letter">
                                        <span class="letter">@letter.Letter</span>
                                        <TmProgressBar Value="@letter.ErrorRate" Max="1" />
                                        <span class="error-rate">@L["Analysis.ErrorRate", (int)(letter.ErrorRate * 100)]</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="analysis-card" data-testid="ai-category-performance">
                        <h3>@L["Analysis.CategoryPerformance"]</h3>
                        @if (analysis.CategoryPerformance.Count == 0)
                        {
                            <p class="empty-hint" data-testid="ai-category-performance-empty">@L["Analysis.CategoryPerformance.Empty"]</p>
                        }
                        else
                        {
                            <div class="category-list">
                                @foreach (var category in analysis.CategoryPerformance)
                                {
                                    <div class="category-item" data-testid="ai-category-row">
                                        <span class="category-name">@category.Category</span>
                                        <div class="category-stats">
                                            <TmBadge Variant="@GetSuccessRateVariant(category.SuccessRate)">
                                                @L["Analysis.SuccessRate", (int)(category.SuccessRate * 100)]
                                            </TmBadge>
                                            <span class="avg-time">@L["Analysis.AvgTime", category.AvgTimeSeconds]</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                @if (analysis.Tips.Count > 0)
                {
                    <div class="tips-card" data-testid="ai-tips">
                        <h3>@L["Analysis.Tips"]</h3>
                        <ul class="tips-list">
                            @foreach (var tip in analysis.Tips)
                            {
                                <li>@tip</li>
                            }
                        </ul>
                    </div>
                }
            </section>
        }

        <section class="challenges-section">
            <h2>@L["Challenges.Title"]</h2>

            @if (previewErrorMessage is not null)
            {
                <TmAlert Severity="AlertSeverity.Warning">@previewErrorMessage</TmAlert>
            }

            <div class="challenges-grid" data-testid="ai-challenge-grid">
                @foreach (var type in ChallengeTypes)
                {
                    <article class="challenge-card" data-testid="ai-challenge-card">
                        <div class="challenge-icon" aria-hidden="true">
                            <TmIcon Name="@GetChallengeIcon(type)" />
                        </div>
                        <h3>@L[GetChallengeTitleKey(type)]</h3>
                        <p>@L[GetChallengeDescriptionKey(type)]</p>

                        <div class="preview-block">
                            <h4>@L["Preview.Title"]</h4>
                            @if (previewLoading.Contains(type))
                            {
                                <p class="preview-loading">@L["Preview.Loading"]</p>
                            }
                            else if (previews.TryGetValue(type, out var preview) && preview.Words.Count > 0)
                            {
                                <div class="preview-words">
                                    @for (var i = 0; i < preview.Words.Take(3).Count(); i++)
                                    {
                                        var word = preview.Words[i];
                                        var reasonKey = $"{type}-{i}";

                                        <div class="preview-word">
                                            <span class="preview-word-text" data-testid="ai-preview-word">@word.Word</span>
                                            <button type="button"
                                                    class="reason-toggle"
                                                    data-testid="ai-preview-reason-toggle"
                                                    @onclick="() => ToggleReason(reasonKey)">
                                                @L["Preview.ReasonButton"]
                                            </button>
                                            @if (openReasonKey == reasonKey)
                                            {
                                                <div class="reason-tooltip" data-testid="ai-preview-reason-tooltip">
                                                    <strong>@L["Preview.Reason.Title"]</strong>
                                                    <span>@word.Reason</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                <p class="predicted-difficulty">
                                    @L["Preview.Difficulty", (int)(preview.PredictedDifficulty * 100)]
                                </p>
                            }
                            else
                            {
                                <p class="empty-hint">@L["Preview.Empty"]</p>
                            }
                        </div>

                        <button type="button"
                                class="start-button"
                                data-testid="@GetStartTestId(type)"
                                disabled="@isGenerating"
                                @onclick="() => StartChallengeAsync(type)">
                            @(startingType == type ? L["Challenge.Generating"] : L["Button.Start"])
                        </button>
                    </article>
                }
            </div>
        </section>
    }
</div>

@code {
    private static readonly AIChallengeType[] ChallengeTypes =
    [
        AIChallengeType.WeaknessFocus,
        AIChallengeType.SpeedTraining,
        AIChallengeType.MemoryGame,
        AIChallengeType.PatternRecognition
    ];

    private readonly Dictionary<AIChallengeType, AIChallengeDto> previews = [];
    private readonly HashSet<AIChallengeType> previewLoading = [];

    private PlayerAnalysisDto? analysis;
    private bool isLoading = true;
    private bool isGenerating;
    private AIChallengeType? startingType;
    private string? errorMessage;
    private string? previewErrorMessage;
    private string? openReasonKey;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        isLoading = true;
        errorMessage = null;
        previewErrorMessage = null;

        analysis = await AIChallengeClient.GetAnalysisAsync();
        if (analysis is null)
        {
            errorMessage = L["Error.AnalysisFailed"].Value;
            isLoading = false;
            return;
        }

        await LoadPreviewsAsync();
        isLoading = false;
    }

    private async Task LoadPreviewsAsync()
    {
        previewLoading.Clear();
        previews.Clear();

        foreach (var type in ChallengeTypes)
        {
            previewLoading.Add(type);
        }

        foreach (var type in ChallengeTypes)
        {
            var preview = await AIChallengeClient.GenerateChallengeAsync(type);
            previewLoading.Remove(type);

            if (preview is null)
            {
                previewErrorMessage = L["Error.GenerateFailed"].Value;
                continue;
            }

            previews[type] = preview;
        }
    }

    private async Task StartChallengeAsync(AIChallengeType type)
    {
        if (isGenerating)
        {
            return;
        }

        isGenerating = true;
        startingType = type;
        errorMessage = null;

        var result = await GameService.StartGameAsync(new StartGameRequest(
            Mode: GameMode.AIChallenge,
            Difficulty: null,
            AiChallengeType: type));

        if (result is null)
        {
            errorMessage = L["Error.GenerateFailed"].Value;
            isGenerating = false;
            startingType = null;
            return;
        }

        Navigation.NavigateTo($"/game/{result.SessionId}");
    }

    private void ToggleReason(string reasonKey)
    {
        openReasonKey = openReasonKey == reasonKey ? null : reasonKey;
    }

    private static BadgeVariant GetSuccessRateVariant(double rate) => rate switch
    {
        >= 0.8 => BadgeVariant.Success,
        >= 0.5 => BadgeVariant.Warning,
        _ => BadgeVariant.Danger
    };

    private static string GetChallengeTitleKey(AIChallengeType type) => type switch
    {
        AIChallengeType.WeaknessFocus => "Challenge.WeaknessFocus.Title",
        AIChallengeType.SpeedTraining => "Challenge.SpeedTraining.Title",
        AIChallengeType.MemoryGame => "Challenge.MemoryGame.Title",
        AIChallengeType.PatternRecognition => "Challenge.PatternRecognition.Title",
        _ => "Page.Title"
    };

    private static string GetChallengeDescriptionKey(AIChallengeType type) => type switch
    {
        AIChallengeType.WeaknessFocus => "Challenge.WeaknessFocus.Description",
        AIChallengeType.SpeedTraining => "Challenge.SpeedTraining.Description",
        AIChallengeType.MemoryGame => "Challenge.MemoryGame.Description",
        AIChallengeType.PatternRecognition => "Challenge.PatternRecognition.Description",
        _ => "Page.Subtitle"
    };

    private static string GetChallengeIcon(AIChallengeType type) => type switch
    {
        AIChallengeType.WeaknessFocus => "target",
        AIChallengeType.SpeedTraining => "zap",
        AIChallengeType.MemoryGame => "award",
        AIChallengeType.PatternRecognition => "grid",
        _ => "sparkles"
    };

    private static string GetStartTestId(AIChallengeType type) => type switch
    {
        AIChallengeType.WeaknessFocus => "ai-start-weakness-focus",
        AIChallengeType.SpeedTraining => "ai-start-speed-training",
        AIChallengeType.MemoryGame => "ai-start-memory-game",
        AIChallengeType.PatternRecognition => "ai-start-pattern-recognition",
        _ => "ai-start"
    };
}
