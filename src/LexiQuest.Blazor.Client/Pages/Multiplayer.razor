@page "/multiplayer"
@inject IStringLocalizer<Multiplayer> Localizer
@inject NavigationManager NavigationManager
@inject IMatchHubClient MatchHubClient

<div class="multiplayer-page" data-testid="multiplayer-page">
    @if (!string.IsNullOrWhiteSpace(_roomError))
    {
        <TmAlert Severity="AlertSeverity.Error" Class="room-error" AdditionalAttributes="@TestId("private-room-error")">
            @_roomError
        </TmAlert>
    }

    <div class="page-header">
        <h1 class="page-title">@Localizer["Page_Title"]</h1>
        <p class="page-subtitle">@Localizer["Page_Subtitle"]</p>
    </div>

    <div class="game-modes">
        <!-- Quick Match Card -->
        <div class="game-mode-card quick-match-card" data-testid="multiplayer-quick-match-card">
            <div class="card-icon">⚔️</div>
            <h2 class="card-title">@Localizer["QuickMatch_Title"]</h2>
            <p class="card-description">@Localizer["QuickMatch_Description"]</p>
            
            <div class="card-badges">
                <TmBadge Variant="BadgeVariant.Success" Size="BadgeSize.Md">
                    @Localizer["QuickMatch_LeagueXP"]
                </TmBadge>
            </div>

            <div class="card-rules">
                <div class="rule">
                    <TmIcon Name="check" Size="IconSize.Sm" Color="IconColor.Success" />
                    <span>@Localizer["QuickMatch_Rule_Words"]</span>
                </div>
                <div class="rule">
                    <TmIcon Name="check" Size="IconSize.Sm" Color="IconColor.Success" />
                    <span>@Localizer["QuickMatch_Rule_Time"]</span>
                </div>
                <div class="rule">
                    <TmIcon Name="check" Size="IconSize.Sm" Color="IconColor.Success" />
                    <span>@Localizer["QuickMatch_Rule_Matchmaking"]</span>
                </div>
            </div>

            <button type="button" class="mode-action primary" data-testid="multiplayer-quick-match-start" @onclick="StartQuickMatch">
                @Localizer["QuickMatch_Button"]
            </button>
        </div>

        <!-- Private Room Card -->
        <div class="game-mode-card private-room-card" data-testid="multiplayer-private-room-card">
            <div class="card-icon">🏠</div>
            <h2 class="card-title">@Localizer["PrivateRoom_Title"]</h2>
            <p class="card-description">@Localizer["PrivateRoom_Description"]</p>
            
            <div class="card-badges">
                <TmBadge Variant="BadgeVariant.Warning" Size="BadgeSize.Md">
                    @Localizer["PrivateRoom_NoLeagueXP"]
                </TmBadge>
            </div>

            <div class="private-room-actions">
                <button type="button" class="mode-action primary" data-testid="multiplayer-create-room" @onclick="ShowCreateRoomModal">
                    @Localizer["PrivateRoom_CreateButton"]
                </button>
                <button type="button" class="mode-action secondary" data-testid="multiplayer-join-room" @onclick="ShowJoinRoomModal">
                    @Localizer["PrivateRoom_JoinButton"]
                </button>
            </div>
        </div>
    </div>

    <!-- Match History Link -->
    <div class="history-section">
        <button type="button" class="history-link" data-testid="multiplayer-match-history" @onclick="GoToHistory">
            @Localizer["MatchHistory_Link"]
        </button>
    </div>
</div>

<!-- Create Room Modal -->
<CreateRoomModal 
    IsVisible="_showCreateRoomModal"
    OnClose="() => _showCreateRoomModal = false"
    OnCreate="CreateRoom" />

<!-- Join Room Modal -->
<JoinRoomModal 
    IsVisible="_showJoinRoomModal"
    OnClose="() => _showJoinRoomModal = false"
    OnJoin="JoinRoom" />

@code {
    private bool _showCreateRoomModal = false;
    private bool _showJoinRoomModal = false;
    private string? _roomError;

    private void StartQuickMatch()
    {
        NavigationManager.NavigateTo("/multiplayer/quick-match");
    }

    private void ShowCreateRoomModal()
    {
        _roomError = null;
        _showCreateRoomModal = true;
    }

    private void ShowJoinRoomModal()
    {
        _roomError = null;
        _showJoinRoomModal = true;
    }

    private void GoToHistory()
    {
        NavigationManager.NavigateTo("/multiplayer/history");
    }

    private async Task CreateRoom(RoomSettingsDto settings)
    {
        _showCreateRoomModal = false;
        await MatchHubClient.StartAsync();
        var roomCreatedTask = WaitForRoomCreatedAsync();
        await MatchHubClient.CreateRoomAsync(settings);
        var room = await roomCreatedTask;

        if (room != null)
        {
            NavigationManager.NavigateTo($"/multiplayer/room/{room.RoomCode}");
        }
    }

    private async Task JoinRoom(string roomCode)
    {
        _showJoinRoomModal = false;
        await MatchHubClient.StartAsync();
        var roomJoinedTask = WaitForRoomJoinedAsync();
        await MatchHubClient.JoinRoomAsync(roomCode);
        var joinedRoomCode = await roomJoinedTask;

        if (!string.IsNullOrWhiteSpace(joinedRoomCode))
        {
            NavigationManager.NavigateTo($"/multiplayer/room/{joinedRoomCode}");
        }
    }

    private async Task<RoomCreatedEvent?> WaitForRoomCreatedAsync()
    {
        var completion = new TaskCompletionSource<RoomCreatedEvent?>(TaskCreationOptions.RunContinuationsAsynchronously);

        void Created(object? sender, RoomCreatedEvent room) => completion.TrySetResult(room);
        void Failed(object? sender, string error)
        {
            _roomError = error;
            completion.TrySetResult(null);
        }

        MatchHubClient.OnRoomCreated += Created;
        MatchHubClient.OnRoomCreationFailed += Failed;

        try
        {
            var completedTask = await Task.WhenAny(completion.Task, Task.Delay(TimeSpan.FromSeconds(10)));
            if (completedTask != completion.Task)
            {
                _roomError = Localizer["Room_LoadFailed"];
                return null;
            }

            return await completion.Task;
        }
        finally
        {
            MatchHubClient.OnRoomCreated -= Created;
            MatchHubClient.OnRoomCreationFailed -= Failed;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<string?> WaitForRoomJoinedAsync()
    {
        var completion = new TaskCompletionSource<string?>(TaskCreationOptions.RunContinuationsAsynchronously);

        void Joined(object? sender, string roomCode) => completion.TrySetResult(roomCode);
        void Failed(object? sender, string error)
        {
            _roomError = error;
            completion.TrySetResult(null);
        }

        MatchHubClient.OnRoomJoined += Joined;
        MatchHubClient.OnRoomJoinFailed += Failed;

        try
        {
            var completedTask = await Task.WhenAny(completion.Task, Task.Delay(TimeSpan.FromSeconds(10)));
            if (completedTask != completion.Task)
            {
                _roomError = Localizer["Room_LoadFailed"];
                return null;
            }

            return await completion.Task;
        }
        finally
        {
            MatchHubClient.OnRoomJoined -= Joined;
            MatchHubClient.OnRoomJoinFailed -= Failed;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static Dictionary<string, object> TestId(string value) =>
        new() { ["data-testid"] = value };
}
