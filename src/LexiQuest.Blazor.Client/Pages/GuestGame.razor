@page "/play"
@page "/play/{SessionId:guid}"
@layout LandingLayout
@using System.Text.Json
@using LexiQuest.Blazor.Components.Game
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Game
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@inject IGuestGameService GuestGameService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<GuestGame> L
@inject IJSRuntime JSRuntime

<PageTitle>@L["Title"]</PageTitle>

<div class="guest-game-page" role="main" data-testid="guest-game-page">
    <div class="back-button-wrapper">
        <button class="back-button tm-btn" data-testid="btn-back" @onclick="GoBack">
            @L["BackToHome"]
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="loading-container">
            <TmSkeleton Type="Rectangle" Height="100px" Class="loading-skeleton" />
            <p class="loading-text">@L["Loading"]</p>
        </div>
    }
    else if (_rateLimitReached)
    {
        <GuestLimitReached
            OnRegister="NavigateToRegister"
            OnLogin="NavigateToLogin"
            OnBack="GoBack" />
    }
    else if (_session == null)
    {
        <div class="welcome-container" data-testid="guest-welcome">
            <div class="welcome-card">
                <div class="welcome-icon">
                    <TmIcon Name="@IconNames.User" Class="icon-user" />
                </div>
                <h1 class="welcome-title">@L["Welcome"]</h1>
                <p class="welcome-description">@L["GuestDescription"]</p>
                <button class="guest-button guest-button-primary guest-button-lg" type="button" @onclick="StartGame" data-testid="btn-start-guest">
                    @L["StartGame"]
                </button>
                <div class="login-prompt">
                    <span>@L["AlreadyHaveAccount"]</span>
                    <button class="guest-link-button" type="button" @onclick="NavigateToLogin">
                        @L["Login"]
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="game-container" data-testid="game-arena">
            <div class="game-card">
                <div class="game-header">
                    <div class="progress-info">
                        <span class="guest-pill guest-pill-primary">
                            @string.Format(L["WordProgress"], _currentWordIndex + 1, _session.ScrambledWords.Count)
                        </span>
                        <span class="guest-pill guest-pill-muted" data-testid="remaining-games">
                            @string.Format(L["RemainingGames"], _session.RemainingGames)
                        </span>
                    </div>
                    <div class="xp-display">
                        <TmIcon Name="@IconNames.Star" Class="xp-icon" />
                        <span>@string.Format(L["SessionXp"], _totalSessionXp)</span>
                    </div>
                </div>

                <div class="word-display">
                    <span class="scrambled-word" data-testid="guest-scrambled-word">@_currentWord?.Scrambled</span>
                </div>

                <div class="answer-section">
                    <LetterTileInput ScrambledWord="@(_currentWord?.Scrambled ?? string.Empty)"
                                     Value="@_currentAnswer"
                                     ValueChanged="HandleTileAnswerChanged"
                                     Disabled="@_showingFeedback"
                                     MaxLength="@(_currentWord?.Length ?? _currentWord?.Scrambled.Length ?? 0)"
                                     RootTestId="guest-letter-input" />

                    <div class="keyboard-answer-row">
                        <input type="text"
                            value="@_currentAnswer"
                            @oninput="HandleAnswerInput"
                            @onkeydown="HandleAnswerKeyDown"
                            placeholder="@L["EnterAnswer"]"
                            disabled="@_showingFeedback"
                            class="answer-input tm-input"
                            aria-label="@L["EnterAnswer"]"
                            autocomplete="off"
                            autofocus
                            data-testid="answer-input" />
                        <button class="guest-button guest-button-primary"
                            @onclick="SubmitAnswer"
                            type="button"
                            disabled="@(string.IsNullOrWhiteSpace(_currentAnswer) || _showingFeedback)"
                            data-testid="btn-submit">
                            @L["Submit"]
                        </button>
                    </div>
                </div>

                @if (_showingFeedback)
                {
                    <div class="feedback @(_lastAnswerCorrect ? "correct" : "incorrect")"
                        role="status"
                        data-testid="answer-feedback">
                        <TmIcon Name="@(_lastAnswerCorrect ? IconNames.Check : IconNames.X)" />
                        <span>@(_lastAnswerCorrect ? L["Correct"] : $"{L["Wrong"]}: {_lastCorrectAnswer}")</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

<GuestCTAModal
    IsOpen="_showCTAModal"
    OnClose="CloseCtaModal"
    OnLater="ContinueGame"
    OnRegister="NavigateToRegister" />

<GuestConvertModal
    IsOpen="_showConvertModal"
    WordsSolved="_wordsSolved"
    TotalXp="_totalSessionXp"
    OnClose="CloseConvertModal"
    OnPlayAgain="ResetGame"
    OnRegister="NavigateToRegisterWithProgress" />

@code {
    [Parameter]
    public Guid? SessionId { get; set; }

    private bool _isLoading = true;
    private bool _rateLimitReached = false;
    private GuestStartResponse? _session;
    private int _currentWordIndex = 0;
    private GuestScrambledWordDto? _currentWord => _session?.ScrambledWords.ElementAtOrDefault(_currentWordIndex);
    private string _currentAnswer = "";
    private bool _showingFeedback = false;
    private bool _lastAnswerCorrect = false;
    private string? _lastCorrectAnswer;
    private int _totalSessionXp = 0;
    private int _wordsSolved = 0;
    private bool _showCTAModal = false;
    private bool _showConvertModal = false;
    private bool _isConverting = false;
    private int _feedbackVersion = 0;
    private const string GuestProgressStorageKey = "guest_progress";

    protected override async Task OnInitializedAsync()
    {
        if (SessionId.HasValue)
        {
            await LoadExistingSession(SessionId.Value);
        }
        _isLoading = false;
    }

    private async Task LoadExistingSession(Guid sessionId)
    {
        _session = await GuestGameService.GetSessionAsync(sessionId);
    }

    private async Task StartGame()
    {
        _isLoading = true;
        _session = await GuestGameService.StartGameAsync();
        _isLoading = false;

        if (_session == null)
        {
            _rateLimitReached = true;
        }
        else
        {
            _currentWordIndex = 0;
            _totalSessionXp = 0;
            _wordsSolved = 0;
            _currentAnswer = "";
            _showingFeedback = false;
            _lastAnswerCorrect = false;
            _lastCorrectAnswer = null;
            _feedbackVersion++;
        }
    }

    private void HandleAnswerInput(ChangeEventArgs e)
    {
        _currentAnswer = e.Value?.ToString() ?? "";
    }

    private async Task HandleAnswerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitAnswer();
        }
        else if (e.Key == "Escape" && !_showingFeedback)
        {
            _currentAnswer = "";
        }
    }

    private void HandleTileAnswerChanged(string answer)
    {
        _currentAnswer = answer;
    }

    private async Task SubmitAnswer()
    {
        if (_session == null || _currentWord == null || string.IsNullOrWhiteSpace(_currentAnswer))
            return;

        var response = await GuestGameService.SubmitAnswerAsync(
            _session.SessionId,
            _currentWord.WordId,
            _currentAnswer.Trim());

        if (response == null)
            return;

        _showingFeedback = true;
        var feedbackVersion = ++_feedbackVersion;
        _lastAnswerCorrect = response.IsCorrect;
        _lastCorrectAnswer = response.CorrectAnswer;
        _totalSessionXp = response.TotalSessionXp;

        if (response.IsCorrect)
        {
            _wordsSolved++;
        }

        if (response.IsGameComplete)
        {
            _showConvertModal = true;
        }
        else if (response.IsCorrect)
        {
            _showCTAModal = true;
            _currentAnswer = "";
        }
        else
        {
            _currentAnswer = "";
            _ = HideFeedbackAfterDelayAsync(feedbackVersion);
        }

        StateHasChanged();
    }

    private void ContinueGame()
    {
        _showCTAModal = false;
        _showingFeedback = false;
        _feedbackVersion++;
        _currentWordIndex++;
        _currentAnswer = "";
    }

    private void CloseCtaModal()
    {
        _showCTAModal = false;
    }

    private void CloseConvertModal()
    {
        _showConvertModal = false;
    }

    private void ResetGame()
    {
        _showConvertModal = false;
        _session = null;
        _currentWordIndex = 0;
        _totalSessionXp = 0;
        _wordsSolved = 0;
        _currentAnswer = "";
        _showingFeedback = false;
        _lastAnswerCorrect = false;
        _lastCorrectAnswer = null;
        _feedbackVersion++;
    }

    private async Task HideFeedbackAfterDelayAsync(int feedbackVersion)
    {
        await Task.Delay(TimeSpan.FromSeconds(3));

        if (feedbackVersion != _feedbackVersion)
        {
            return;
        }

        _showingFeedback = false;
        await InvokeAsync(StateHasChanged);
    }

    private void NavigateToRegister()
    {
        NavigationManager.NavigateTo("/register");
    }

    private void NavigateToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }

    private async Task NavigateToRegisterWithProgress()
    {
        if (_session == null)
        {
            NavigationManager.NavigateTo("/register");
            return;
        }

        _isConverting = true;
        StateHasChanged();

        try
        {
            var conversion = await GuestGameService.ConvertAsync(_session.SessionId, transferProgress: true);
            if (conversion?.Success == true && !string.IsNullOrWhiteSpace(conversion.TransferToken))
            {
                var progress = new GuestProgressStorage(
                    conversion.TransferToken,
                    conversion.TransferredXp,
                    conversion.TransferredWordsSolved,
                    DateTimeOffset.UtcNow);

                await JSRuntime.InvokeVoidAsync(
                    "localStorage.setItem",
                    GuestProgressStorageKey,
                    JsonSerializer.Serialize(progress));

                NavigationManager.NavigateTo("/register?guestProgress=1");
                return;
            }

            NavigationManager.NavigateTo("/register");
        }
        finally
        {
            _isConverting = false;
        }
    }

    private void GoBack()
    {
        try
        {
            NavigationManager.NavigateTo("/");
        }
        catch (InvalidOperationException)
        {
            // Fallback for uninitialized NavigationManager
        }
    }

    private sealed record GuestProgressStorage(
        string TransferToken,
        int TransferredXp,
        int TransferredWordsSolved,
        DateTimeOffset CreatedAtUtc);
}
