@page "/play"
@page "/play/{SessionId:guid}"
@layout MainLayout
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Game
@using Microsoft.Extensions.Localization
@inject IGuestGameService GuestGameService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<GuestGame> L

<PageTitle>@L["Title"]</PageTitle>

<div class="guest-game-page" role="main">
    <div class="back-button-wrapper">
        <button class="back-button tm-btn" data-testid="btn-back" @onclick="GoBack">
            @L["BackToHome"]
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="loading-container">
            <TmSkeleton Type="Rectangle" Height="100px" Class="loading-skeleton" />
            <p class="loading-text">@L["Loading"]</p>
        </div>
    }
    else if (_rateLimitReached)
    {
        <div class="guest-limit-reached" data-testid="guest-limit-reached">
            <TmCard Variant="CardVariant.Elevated" Class="limit-card">
                <h2 class="limit-title">@L["Error_RateLimit"]</h2>
                <div class="limit-actions">
                    <TmButton Variant="ButtonVariant.Primary" OnClick="NavigateToRegister">
                        @L["Login"]
                    </TmButton>
                    <TmButton Variant="ButtonVariant.Ghost" OnClick="GoBack">
                        @L["BackToHome"]
                    </TmButton>
                </div>
            </TmCard>
        </div>
    }
    else if (_session == null)
    {
        <div class="welcome-container" data-testid="guest-welcome">
            <TmCard Variant="CardVariant.Elevated" Class="welcome-card">
                <div class="welcome-icon">
                    <TmIcon Name="@IconNames.User" Class="icon-user" />
                </div>
                <h1 class="welcome-title">@L["Welcome"]</h1>
                <p class="welcome-description">@L["GuestDescription"]</p>
                <button class="tm-btn tm-btn-primary tm-btn-lg" @onclick="StartGame" data-testid="btn-start-guest">
                    @L["StartGame"]
                </button>
                <div class="login-prompt">
                    <span>@L["AlreadyHaveAccount"]</span>
                    <TmButton Variant="ButtonVariant.Link" OnClick="NavigateToLogin">
                        @L["Login"]
                    </TmButton>
                </div>
            </TmCard>
        </div>
    }
    else
    {
        <div class="game-container" data-testid="game-arena">
            <TmCard Variant="CardVariant.Elevated" Class="game-card">
                <div class="game-header">
                    <div class="progress-info">
                        <TmBadge Variant="BadgeVariant.Primary">
                            @string.Format(L["WordProgress"], _currentWordIndex + 1, _session.ScrambledWords.Count)
                        </TmBadge>
                        <span class="tm-badge" data-testid="remaining-games">
                            @string.Format(L["RemainingGames"], _session.RemainingGames)
                        </span>
                    </div>
                    <div class="xp-display">
                        <TmIcon Name="@IconNames.Star" Class="xp-icon" />
                        <span>@string.Format(L["SessionXp"], _totalSessionXp)</span>
                    </div>
                </div>

                <div class="word-display">
                    <span class="scrambled-word">@_currentWord?.Scrambled</span>
                </div>

                <div class="answer-section">
                    <input type="text"
                        value="@_currentAnswer"
                        @oninput="HandleAnswerInput"
                        placeholder="@L["EnterAnswer"]"
                        disabled="@_showingFeedback"
                        class="answer-input tm-input"
                        aria-label="@L["EnterAnswer"]"
                        autocomplete="off"
                        data-testid="answer-input" />
                    <button class="tm-btn tm-btn-primary"
                        @onclick="SubmitAnswer"
                        disabled="@(string.IsNullOrWhiteSpace(_currentAnswer) || _showingFeedback)"
                        data-testid="btn-submit">
                        @L["Submit"]
                    </button>
                </div>

                @if (_showingFeedback)
                {
                    <div class="feedback @(_lastAnswerCorrect ? "correct" : "incorrect")">
                        <TmIcon Name="@(_lastAnswerCorrect ? IconNames.Check : IconNames.X)" />
                        <span>@(_lastAnswerCorrect ? L["Correct"] : $"{L["Wrong"]}: {_lastCorrectAnswer}")</span>
                    </div>
                }
            </TmCard>
        </div>
    }
</div>

@if (_showCTAModal)
{
    <div class="modal-overlay" @onclick="() => _showCTAModal = false" role="dialog" aria-modal="true" aria-label="@L["Welcome"]">
        <div class="modal-content" @onclick:stopPropagation data-testid="guest-cta-modal">
            <div class="modal-header">
                <h3>@L["Welcome"]</h3>
            </div>
            <div class="modal-footer">
                <TmButton Variant="ButtonVariant.Outline" OnClick="ContinueGame">
                    @L["BackToHome"]
                </TmButton>
                <TmButton Variant="ButtonVariant.Primary" OnClick="NavigateToRegister">
                    @L["Login"]
                </TmButton>
            </div>
        </div>
    </div>
}

@if (_showConvertModal)
{
    <div class="modal-overlay" @onclick="() => _showConvertModal = false" role="dialog" aria-modal="true" aria-label="@L["Welcome"]">
        <div class="modal-content" @onclick:stopPropagation data-testid="guest-convert-modal">
            <div class="modal-header">
                <h3>@L["Welcome"]</h3>
            </div>
            <div class="modal-body">
                <span>@_wordsSolved</span>
                <span>@_totalSessionXp</span>
            </div>
            <div class="modal-footer">
                <TmButton Variant="ButtonVariant.Outline" OnClick="ResetGame">
                    @L["StartGame"]
                </TmButton>
                <TmButton Variant="ButtonVariant.Primary" OnClick="NavigateToRegisterWithProgress">
                    @L["Login"]
                </TmButton>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid? SessionId { get; set; }

    private bool _isLoading = true;
    private bool _rateLimitReached = false;
    private GuestStartResponse? _session;
    private int _currentWordIndex = 0;
    private GuestScrambledWordDto? _currentWord => _session?.ScrambledWords.ElementAtOrDefault(_currentWordIndex);
    private string _currentAnswer = "";
    private bool _showingFeedback = false;
    private bool _lastAnswerCorrect = false;
    private string? _lastCorrectAnswer;
    private int _totalSessionXp = 0;
    private int _wordsSolved = 0;
    private bool _showCTAModal = false;
    private bool _showConvertModal = false;

    protected override async Task OnInitializedAsync()
    {
        if (SessionId.HasValue)
        {
            await LoadExistingSession(SessionId.Value);
        }
        _isLoading = false;
    }

    private async Task LoadExistingSession(Guid sessionId)
    {
        _session = await GuestGameService.GetSessionAsync(sessionId);
    }

    private async Task StartGame()
    {
        _isLoading = true;
        _session = await GuestGameService.StartGameAsync();
        _isLoading = false;

        if (_session == null)
        {
            _rateLimitReached = true;
        }
        else
        {
            _currentWordIndex = 0;
            _totalSessionXp = 0;
            _wordsSolved = 0;
            _currentAnswer = "";
        }
    }

    private void HandleAnswerInput(ChangeEventArgs e)
    {
        _currentAnswer = e.Value?.ToString() ?? "";
    }

    private async Task SubmitAnswer()
    {
        if (_session == null || _currentWord == null || string.IsNullOrWhiteSpace(_currentAnswer))
            return;

        var response = await GuestGameService.SubmitAnswerAsync(
            _session.SessionId,
            _currentWord.WordId,
            _currentAnswer.Trim());

        if (response == null)
            return;

        _showingFeedback = true;
        _lastAnswerCorrect = response.IsCorrect;
        _lastCorrectAnswer = response.CorrectAnswer;
        _totalSessionXp = response.TotalSessionXp;

        if (response.IsCorrect)
        {
            _wordsSolved++;
        }

        if (response.IsGameComplete)
        {
            _showConvertModal = true;
        }
        else if (response.IsCorrect)
        {
            _showCTAModal = true;
            _currentWordIndex++;
            _currentAnswer = "";
        }

        _showingFeedback = false;
        StateHasChanged();
    }

    private void ContinueGame()
    {
        _showCTAModal = false;
        _currentWordIndex++;
        _currentAnswer = "";
    }

    private void ResetGame()
    {
        _showConvertModal = false;
        _session = null;
        _currentWordIndex = 0;
        _totalSessionXp = 0;
        _wordsSolved = 0;
        _currentAnswer = "";
    }

    private void NavigateToRegister()
    {
        NavigationManager.NavigateTo("/register");
    }

    private void NavigateToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }

    private void NavigateToRegisterWithProgress()
    {
        NavigationManager.NavigateTo($"/register?guestSession={_session?.SessionId}");
    }

    private void GoBack()
    {
        try
        {
            NavigationManager.NavigateTo("/");
        }
        catch (InvalidOperationException)
        {
            // Fallback for uninitialized NavigationManager
        }
    }
}
