@page "/leagues"
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Leagues
@using LexiQuest.Shared.Enums
@inject ILeagueService LeagueService
@inject IStringLocalizer<Leagues> L

<div class="leagues-page" data-testid="leagues-page">
    @if (isLoading)
    {
        <div class="loading-state">
            <TmSkeleton Type="Rectangle" Height="200px" />
            <TmSkeleton Type="Rectangle" Height="100px" />
            <TmSkeleton Type="Rectangle" Height="400px" />
        </div>
    }
    else if (leagueInfo == null)
    {
        <div class="empty-state">
            <TmEmptyState
                Icon="trophy"
                Title="@L["EmptyState.Title"]"
                Description="@L["EmptyState.Description"]" />
        </div>
    }
    else
    {
        <div class="league-header">
            <TmCard Variant="CardVariant.Elevated">
                <div class="tier-header-content">
                    <TmIcon Name="@GetTierIcon(leagueInfo.Tier)"   />
                    <div class="tier-info">
                        <h1 data-testid="league-tier">@GetTierName(leagueInfo.Tier)</h1>
                        <p>@L["WeekInfo", leagueInfo.WeekStart.ToString("dd.MM"), leagueInfo.WeekEnd.ToString("dd.MM")]</p>
                    </div>
                </div>
            </TmCard>
        </div>

        <div class="time-remaining-card @GetCountdownContainerClass(leagueInfo.WeekEnd)">
            <TmCard>
                <div class="@GetCountdownContentClass(leagueInfo.WeekEnd)"
                     data-testid="league-reset-countdown"
                     data-state="@GetCountdownState(leagueInfo.WeekEnd)">
                    <TmIcon Name="clock" />
                    <span>@L["TimeRemaining", FormatTimeRemaining(leagueInfo.WeekEnd)]</span>
                </div>
            </TmCard>
        </div>

        <div class="user-position-card" data-testid="league-user-position">
            <TmCard Variant="CardVariant.Elevated">
                <div class="rank-display">#@leagueInfo.CurrentRank / @leagueInfo.TotalParticipants</div>
                <div class="xp-display">@leagueInfo.UserXP XP</div>
            </TmCard>
        </div>

        <div class="progress-section">
            <TmCard>
                <div class="progress-content">
                    <h3>@L["Progress.Title"]</h3>
                    <div class="progress-thresholds">
                        <div class="threshold promotion-threshold">
                            <span class="threshold-label">@L["Progress.Promotion"]</span>
                            <span class="threshold-value">@L["Progress.TopN", leagueInfo.PromotionThreshold]</span>
                            @if (leagueInfo.CurrentRank <= leagueInfo.PromotionThreshold)
                            {
                                <TmBadge Variant="BadgeVariant.Success">@L["Progress.InZone"]</TmBadge>
                            }
                        </div>
                        <div class="progress-bar-container">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: @GetProgressPercentage()%"></div>
                                <div class="progress-marker promotion-marker" style="left: @GetPromotionMarkerPosition()%"></div>
                                @if (HasDemotionZone())
                                {
                                    <div class="progress-marker demotion-marker" style="left: @GetDemotionMarkerPosition()%"></div>
                                }
                            </div>
                            <div class="progress-label">
                                <span>@L["Progress.CurrentRank", leagueInfo.CurrentRank, leagueInfo.TotalParticipants]</span>
                            </div>
                        </div>
                        <div class="threshold demotion-threshold">
                            <span class="threshold-label">@L["Progress.Demotion"]</span>
                            <span class="threshold-value">@GetDemotionThresholdText()</span>
                            @if (HasDemotionZone() && leagueInfo.CurrentRank >= leagueInfo.DemotionThreshold)
                            {
                                <TmBadge Variant="BadgeVariant.Danger">@L["Progress.InDanger"]</TmBadge>
                            }
                        </div>
                    </div>
                </div>
            </TmCard>
        </div>

        <div class="leaderboard-section">
            <h2>@L["LeaderboardTitle"]</h2>
            <div class="leaderboard" data-testid="league-leaderboard">
                @foreach (var p in leaderboard)
                {
                    <div class="leaderboard-row @GetRowClass(p)" data-testid="@GetRowTestId(p)">
                        <span class="rank">#@p.Rank</span>
                        <span class="avatar">@GetInitials(p.Username)</span>
                        <span>@p.Username</span>
                        <span>@p.WeeklyXP XP</span>
                    </div>
                }
            </div>
        </div>

        @if (leagueHistory.Any())
        {
            <div class="history-section" data-testid="league-history">
                <h2>@L["History.Title"]</h2>
                @foreach (var entry in leagueHistory)
                {
                    <TmCard Class="history-entry">
                        <div class="history-entry-content">
                            <div class="history-tier">
                                <TmIcon Name="@GetTierIcon(entry.Tier)" />
                                <span>@GetTierName(entry.Tier)</span>
                            </div>
                            <div class="history-week">
                                <span>@entry.WeekStart.ToString("dd.MM") - @entry.WeekEnd.ToString("dd.MM")</span>
                            </div>
                            <div class="history-stats">
                                <span class="history-rank">@L["History.Rank", entry.FinalRank]</span>
                                <span class="history-xp">@entry.WeeklyXP XP</span>
                                <span class="history-earned">+@entry.XPEarned XP</span>
                            </div>
                            <div class="history-status">
                                <TmBadge Variant="@GetChangeStatusVariant(entry.ChangeStatus)">
                                    @L[$"History.Status.{entry.ChangeStatus}"]
                                </TmBadge>
                            </div>
                        </div>
                    </TmCard>
                }
            </div>
        }

        @if (leagueRewards.Any())
        {
            <div class="rewards-section" data-testid="league-rewards">
                <h2>@L["Rewards.Title"]</h2>
                <div class="rewards-grid">
                    @foreach (var reward in leagueRewards)
                    {
                        <TmCard Class="@($"reward-card {(reward.Tier == leagueInfo.Tier ? "current-tier" : "")}")">
                            <div class="reward-content">
                                <TmIcon Name="@GetTierIcon(reward.Tier)" />
                                <h4>@GetTierName(reward.Tier)</h4>
                                <div class="reward-xp">+@reward.XPReward XP</div>
                                <p class="reward-desc">@reward.Description</p>
                                @if (reward.Tier == leagueInfo.Tier)
                                {
                                    <TmBadge Variant="BadgeVariant.Primary">@L["Rewards.Current"]</TmBadge>
                                }
                            </div>
                        </TmCard>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private LeagueInfoDto? leagueInfo;
    private List<LeagueParticipantDto> leaderboard = new();
    private List<LeagueHistoryDto> leagueHistory = new();
    private List<LeagueRewardsDto> leagueRewards = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        leagueInfo = await LeagueService.GetCurrentLeagueAsync();
        leaderboard = await LeagueService.GetLeaderboardAsync();
        leagueHistory = await LeagueService.GetLeagueHistoryAsync() ?? new();
        leagueRewards = await LeagueService.GetRewardsAsync() ?? new();
        isLoading = false;
    }

    private string GetTierIcon(LeagueTier tier) => tier switch
    {
        LeagueTier.Bronze => "medal",
        LeagueTier.Silver => "award",
        LeagueTier.Gold => "trophy",
        LeagueTier.Diamond => "gem",
        LeagueTier.Legend => "crown",
        _ => "trophy"
    };

    private string GetTierName(LeagueTier tier) => L[$"Tier.{tier}"].Value;

    private string GetRowClass(LeagueParticipantDto p)
    {
        var classes = new List<string>();
        if (p.IsCurrentUser) classes.Add("is-current-user");
        if (p.IsPromoted) classes.Add("promotion-zone");
        if (p.IsDemoted) classes.Add("demotion-zone");
        return string.Join(" ", classes);
    }

    private static string GetRowTestId(LeagueParticipantDto p)
    {
        if (p.IsCurrentUser) return "league-current-user-row";
        if (p.IsPromoted) return "league-promotion-zone";
        if (p.IsDemoted) return "league-demotion-zone";
        return "league-row";
    }

    private static string GetInitials(string username)
    {
        if (string.IsNullOrEmpty(username)) return "?";
        return username[..1].ToUpper();
    }

    private string FormatTimeRemaining(DateTime weekEnd)
    {
        var remaining = weekEnd - DateTime.UtcNow;
        if (remaining <= TimeSpan.Zero)
            return L["TimeRemaining.Ended"].Value;
        if (remaining.TotalDays >= 1)
            return $"{(int)remaining.TotalDays}d {remaining.Hours}h";
        if (remaining.TotalHours >= 1)
            return $"{(int)remaining.TotalHours}h {remaining.Minutes}m";
        return $"{remaining.Minutes}m";
    }

    private static string GetCountdownState(DateTime weekEnd)
    {
        var remaining = weekEnd - DateTime.UtcNow;
        if (remaining <= TimeSpan.Zero) return "ended";
        if (remaining <= TimeSpan.FromHours(6)) return "critical";
        if (remaining <= TimeSpan.FromHours(24)) return "warning";
        return "normal";
    }

    private static string GetCountdownContainerClass(DateTime weekEnd)
    {
        return $"is-{GetCountdownState(weekEnd)}";
    }

    private static string GetCountdownContentClass(DateTime weekEnd)
    {
        return $"time-remaining-content is-{GetCountdownState(weekEnd)}";
    }

    private int GetProgressPercentage()
    {
        if (leagueInfo == null || leagueInfo.TotalParticipants == 0) return 0;
        return (int)(100.0 * (leagueInfo.TotalParticipants - leagueInfo.CurrentRank + 1) / leagueInfo.TotalParticipants);
    }

    private int GetPromotionMarkerPosition()
    {
        if (leagueInfo == null || leagueInfo.TotalParticipants == 0) return 0;
        return (int)(100.0 * (leagueInfo.TotalParticipants - leagueInfo.PromotionThreshold) / leagueInfo.TotalParticipants);
    }

    private int GetDemotionMarkerPosition()
    {
        if (leagueInfo == null || leagueInfo.TotalParticipants == 0) return 0;
        return Math.Clamp((int)(100.0 * (leagueInfo.TotalParticipants - leagueInfo.DemotionThreshold) / leagueInfo.TotalParticipants), 0, 100);
    }

    private bool HasDemotionZone()
    {
        return leagueInfo != null && leagueInfo.DemotionThreshold <= leagueInfo.TotalParticipants;
    }

    private string GetDemotionThresholdText()
    {
        if (HasDemotionZone())
        {
            var belowText = L["Progress.BelowN", leagueInfo!.DemotionThreshold];
            return string.IsNullOrWhiteSpace(belowText?.Value)
                ? $"Od #{leagueInfo.DemotionThreshold}"
                : belowText.Value;
        }

        var noDemotionText = L["Progress.NoDemotion"];
        return string.IsNullOrWhiteSpace(noDemotionText?.Value)
            ? "Bez sestupu"
            : noDemotionText.Value;
    }

    private static BadgeVariant GetChangeStatusVariant(LeagueChangeStatus status) => status switch
    {
        LeagueChangeStatus.Promoted => BadgeVariant.Success,
        LeagueChangeStatus.Demoted => BadgeVariant.Danger,
        _ => BadgeVariant.Default
    };
}
