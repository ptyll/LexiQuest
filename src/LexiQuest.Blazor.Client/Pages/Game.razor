@page "/game"
@page "/game/{SessionId:guid}"
@using LexiQuest.Blazor.Components.Game
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Achievements
@using LexiQuest.Shared.DTOs.Game
@using LexiQuest.Shared.Enums
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@inject IStringLocalizer<Game> L
@inject IGameService GameService
@inject IToastService ToastService
@inject NotificationRefreshService NotificationRefreshService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="game-page" data-testid="game-page">
    @if (IsLoading)
    {
        <div class="loading-state" data-testid="game-loading-state">
            <div class="spinner"></div>
            <p>@L["Loading"]</p>
        </div>
    }
    else if (ErrorMessage != null)
    {
        <div class="error-state" data-testid="game-error-state">
            <p class="error-message">@ErrorMessage</p>
            <button class="btn-retry" data-testid="game-retry" @onclick="StartNewGame">@L["Retry"]</button>
        </div>
    }
    else if (CurrentState != null)
    {
        @if (IsOfflineMode)
        {
            <div class="offline-game-badge" data-testid="game-offline-badge" role="status">
                @L["OfflineTraining"]
            </div>
        }

        <GameArena 
            SessionId="CurrentState.SessionId"
            ScrambledWord="@CurrentState.ScrambledWord"
            CurrentRound="CurrentState.RoundNumber"
            TotalRounds="CurrentState.TotalRounds"
            ComboCount="ComboCount"
            LivesRemaining="CurrentState.LivesRemaining"
            MaxLives="CurrentState.MaxLives"
            IsInfiniteLives="CurrentState.IsInfiniteLives"
            NextLifeRegenAt="CurrentState.NextLifeRegenAt"
            OnSubmitAnswer="HandleSubmitAnswer"
            OnSkipRound="HandleSkipRound"
            OnBack="HandleBack"
            OnLevelComplete="HandleLevelComplete"
            @ref="GameArenaRef" />

        <GameTimer 
            TotalSeconds="CurrentState.TimeLimitSeconds"
            RemainingSeconds="RemainingSeconds"
            OnTimeUp="HandleTimeUp"
            IsPaused="IsPaused" />

        @if (IsLevelUpVisible && LastXpEvent != null)
        {
            <LevelUpModal
                XpEvent="LastXpEvent"
                IsVisible="IsLevelUpVisible"
                OnContinue="HandleLevelUpContinue" />
        }

        @if (IsAchievementUnlockVisible && LastUnlockedAchievements?.Any() == true)
        {
            <div class="achievement-unlock-backdrop" role="dialog" aria-modal="true" data-testid="achievement-unlock-modal">
                <div class="achievement-unlock-dialog">
                    <h2>@L["AchievementUnlocked.Title"]</h2>
                    <div class="achievement-unlock-list">
                        @foreach (var achievement in LastUnlockedAchievements)
                        {
                            <div class="achievement-unlock-item">
                                <div class="achievement-unlock-icon" aria-hidden="true">
                                    <TmIcon Name="award" />
                                </div>
                                <div>
                                    <h3>@achievement.Name</h3>
                                    @if (!string.IsNullOrWhiteSpace(achievement.Description))
                                    {
                                        <p>@achievement.Description</p>
                                    }
                                    <span class="achievement-unlock-xp">+@achievement.XPReward XP</span>
                                </div>
                            </div>
                        }
                    </div>
                    <button class="achievement-unlock-continue"
                            type="button"
                            data-testid="achievement-unlock-continue"
                            @onclick="HandleAchievementUnlockContinue">
                        @L["AchievementUnlocked.Continue"]
                    </button>
                </div>
            </div>
        }
    }
    else
    {
        <div class="start-screen" data-testid="game-start-screen">
            <h1>@L["Welcome"]</h1>
            <p>@L["SelectMode"]</p>
            
            <div class="mode-buttons">
                <button class="btn-mode" data-testid="game-mode-training" @onclick="() => StartGame(GameMode.Training)">
                    @L["Mode_Training"]
                </button>
                <button class="btn-mode" data-testid="game-mode-time-attack" @onclick="() => StartGame(GameMode.TimeAttack)">
                    @L["Mode_TimeAttack"]
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? SessionId { get; set; }

    private ScrambledWordDto? CurrentState { get; set; }
    private GameArena? GameArenaRef { get; set; }
    private bool IsLoading { get; set; } = false;
    private string? ErrorMessage { get; set; }
    private int ComboCount { get; set; } = 0;
    private int TotalXP { get; set; } = 0;
    private int RemainingSeconds { get; set; } = 30;
    private bool IsPaused { get; set; } = false;
    private bool IsOfflineMode { get; set; } = false;
    private XPGainedEvent? LastXpEvent { get; set; }
    private bool IsLevelUpVisible { get; set; } = false;
    private List<AchievementUnlockDto>? LastUnlockedAchievements { get; set; }
    private bool IsAchievementUnlockVisible { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (SessionId.HasValue)
        {
            await LoadGameState(SessionId.Value);
        }
        else if (TryGetPathStartQuery(out var pathId, out var levelNumber))
        {
            await StartPathGame(pathId, levelNumber);
        }
    }

    private async Task StartGame(GameMode mode)
    {
        IsLoading = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            var request = new StartGameRequest(Mode: mode, Difficulty: DifficultyLevel.Beginner);
            IsOfflineMode = mode == GameMode.Training && !await IsOnlineAsync();
            var result = await GameService.StartGameAsync(request);

            if (result != null)
            {
                CurrentState = result;
                RemainingSeconds = result.TimeLimitSeconds;
                ComboCount = 0;
                TotalXP = 0;
                LastXpEvent = null;
                LastUnlockedAchievements = null;
                IsAchievementUnlockVisible = false;
                IsLevelUpVisible = false;
                if (!IsOfflineMode)
                {
                    Navigation.NavigateTo($"/game/{result.SessionId}");
                }
            }
            else
            {
                IsOfflineMode = false;
                ErrorMessage = L["Error_StartingGame"];
            }
        }
        catch (Exception ex)
        {
            IsOfflineMode = false;
            ErrorMessage = L["Error_StartingGame"];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task StartPathGame(Guid pathId, int levelNumber)
    {
        IsLoading = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            var request = new StartGameRequest(
                Mode: GameMode.Path,
                Difficulty: null,
                PathId: pathId,
                LevelNumber: levelNumber);
            var result = await GameService.StartGameAsync(request);

            if (result != null)
            {
                CurrentState = result;
                RemainingSeconds = result.TimeLimitSeconds;
                ComboCount = 0;
                TotalXP = 0;
                LastXpEvent = null;
                LastUnlockedAchievements = null;
                IsAchievementUnlockVisible = false;
                IsLevelUpVisible = false;
                IsOfflineMode = false;
                Navigation.NavigateTo($"/game/{result.SessionId}", replace: true);
            }
            else
            {
                ErrorMessage = L["Error_StartingGame"];
            }
        }
        catch
        {
            ErrorMessage = L["Error_StartingGame"];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadGameState(Guid sessionId)
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var result = await GameService.GetGameStateAsync(sessionId);
            if (result != null)
            {
                CurrentState = result;
                RemainingSeconds = result.TimeLimitSeconds;
                IsOfflineMode = false;
            }
            else
            {
                ErrorMessage = L["Error_GameNotFound"];
            }
        }
        catch (Exception)
        {
            ErrorMessage = L["Error_LoadingGame"];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleSubmitAnswer(string answer)
    {
        if (CurrentState == null) return;

        var timeSpent = (CurrentState.TimeLimitSeconds - RemainingSeconds) * 1000;
        
        var result = await GameService.SubmitAnswerAsync(
            CurrentState.SessionId, 
            answer, 
            timeSpent);

        if (result != null)
        {
            TotalXP += result.XPEarned;
            ComboCount = result.ComboCount;
            CurrentState = CurrentState with
            {
                LivesRemaining = result.LivesRemaining,
                NextLifeRegenAt = result.NextLifeRegenAt ?? CurrentState.NextLifeRegenAt
            };

            if (GameArenaRef != null)
            {
                await GameArenaRef.ShowResult(result, TotalXP);
            }

            if (result.XpEvent?.LeveledUp == true)
            {
                LastXpEvent = result.XpEvent;
                IsLevelUpVisible = true;
                IsPaused = true;
                StateHasChanged();
            }

            if (result.UnlockedAchievements?.Any() == true)
            {
                LastUnlockedAchievements = result.UnlockedAchievements;
                foreach (var achievement in result.UnlockedAchievements)
                {
                    ToastService.ShowSuccess(string.Format(L["AchievementUnlocked.Toast"], achievement.Name));
                }

                IsAchievementUnlockVisible = true;
                IsPaused = true;
                await NotificationRefreshService.RequestRefreshAsync();
                StateHasChanged();
            }

            if (result.IsLevelComplete)
            {
                // Game completed - handled by GameArena overlay
            }
            else if (result.NextScrambledWord != null && result.NextRoundNumber.HasValue)
            {
                // Move to next round
                await Task.Delay(1500); // Short delay to show feedback
                CurrentState = CurrentState with 
                { 
                    ScrambledWord = result.NextScrambledWord,
                    RoundNumber = result.NextRoundNumber.Value,
                    LivesRemaining = result.LivesRemaining,
                    NextLifeRegenAt = result.NextLifeRegenAt ?? CurrentState.NextLifeRegenAt
                };
                RemainingSeconds = CurrentState.TimeLimitSeconds;
                
                if (GameArenaRef != null)
                {
                    await GameArenaRef.UpdateScrambledWord(
                        result.NextScrambledWord, 
                        result.NextRoundNumber.Value);
                }
            }
        }
    }

    private async Task HandleSkipRound()
    {
        // Forfeit current round - treat as wrong answer
        if (CurrentState == null) return;
        
        await HandleSubmitAnswer(""); // Submit empty answer
    }

    private void HandleBack()
    {
        Navigation.NavigateTo("/dashboard");
    }

    private async Task HandleLevelComplete()
    {
        Navigation.NavigateTo("/dashboard");
    }

    private Task HandleLevelUpContinue()
    {
        IsLevelUpVisible = false;
        LastXpEvent = null;
        IsPaused = false;
        return Task.CompletedTask;
    }

    private Task HandleAchievementUnlockContinue()
    {
        IsAchievementUnlockVisible = false;
        LastUnlockedAchievements = null;
        IsPaused = IsLevelUpVisible;
        return Task.CompletedTask;
    }

    private async Task HandleTimeUp()
    {
        if (CurrentState == null) return;
        
        // Time's up - submit empty answer
        await HandleSubmitAnswer("");
    }

    private void StartNewGame()
    {
        CurrentState = null;
        ErrorMessage = null;
        IsOfflineMode = false;
        ComboCount = 0;
        TotalXP = 0;
        LastXpEvent = null;
        LastUnlockedAchievements = null;
        IsAchievementUnlockVisible = false;
        IsLevelUpVisible = false;
        IsPaused = false;
        Navigation.NavigateTo("/game");
    }

    private async Task<bool> IsOnlineAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("lexiQuestPwa.getOnlineStatus");
        }
        catch
        {
            return true;
        }
    }

    private bool TryGetPathStartQuery(out Guid pathId, out int levelNumber)
    {
        pathId = Guid.Empty;
        levelNumber = 0;

        var query = new Uri(Navigation.Uri).Query;
        if (string.IsNullOrWhiteSpace(query))
        {
            return false;
        }

        var values = query.TrimStart('?')
            .Split('&', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => part.Split('=', 2))
            .Where(parts => parts.Length == 2)
            .ToDictionary(
                parts => Uri.UnescapeDataString(parts[0]),
                parts => Uri.UnescapeDataString(parts[1]),
                StringComparer.OrdinalIgnoreCase);

        return values.TryGetValue("pathId", out var pathIdValue)
            && values.TryGetValue("levelNumber", out var levelNumberValue)
            && Guid.TryParse(pathIdValue, out pathId)
            && int.TryParse(levelNumberValue, out levelNumber)
            && levelNumber > 0;
    }
}
