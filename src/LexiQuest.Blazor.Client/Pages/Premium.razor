@page "/premium"
@using LexiQuest.Shared.DTOs.Premium
@inject IStringLocalizer<Premium> L
@inject IPremiumService PremiumService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<PageTitle>@L["Title"] - LexiQuest</PageTitle>

<div class="premium-page" data-testid="premium-page">
    <div class="hero-section">
        <div class="hero-content">
            <TmIcon Name="@IconNames.Star" Class="hero-icon" />
            <h1 class="hero-title">@L["Title"]</h1>
            <p class="hero-subtitle">@L["Subtitle"]</p>

            @if (_status?.IsActive == true)
            {
                <div class="premium-status-actions">
                    <div data-testid="premium-active-badge">
                        <TmBadge Variant="BadgeVariant.Success" Class="premium-active-badge">
                            @L["Status_Active"] - @GetPlanLabel(_status.Plan)
                        </TmBadge>
                    </div>
                    <div data-testid="premium-cancel-subscription">
                        <TmButton Variant="ButtonVariant.Secondary"
                                  OnClick="CancelSubscriptionAsync"
                                  IsLoading="_isCancelling"
                                  Icon="@IconNames.XCircle">
                            @L["Button_CancelSubscription"]
                        </TmButton>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="features-section">
        <div class="features-grid">
            <TmCard Class="feature-group">
                <div class="feature-header">
                    <TmIcon Name="@IconNames.Play" />
                    <h3>@L["Section_GameFeatures"]</h3>
                </div>
                <ul class="feature-list">
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_NoAds"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_StreakFreeze"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_StreakShield"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_DoubleXP"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_ExclusivePaths"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_CustomDictionaries"]</li>
                </ul>
            </TmCard>

            <TmCard Class="feature-group">
                <div class="feature-header">
                    <TmIcon Name="@IconNames.TrendingUp" />
                    <h3>@L["Section_Analytics"]</h3>
                </div>
                <ul class="feature-list">
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_DetailedStats"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_ExportData"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_History"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_Comparison"]</li>
                </ul>
            </TmCard>

            <TmCard Class="feature-group">
                <div class="feature-header">
                    <TmIcon Name="@IconNames.User" />
                    <h3>@L["Section_Personalization"]</h3>
                </div>
                <ul class="feature-list">
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_CustomAvatar"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_ExclusiveAvatars"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_Themes"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_Frames"]</li>
                </ul>
            </TmCard>

            <TmCard Class="feature-group">
                <div class="feature-header">
                    <TmIcon Name="@IconNames.Users" />
                    <h3>@L["Section_Multiplayer"]</h3>
                </div>
                <ul class="feature-list">
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_DiamondLeague"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_Tournaments"]</li>
                    <li><TmIcon Name="@IconNames.Check" /> @L["Feature_TeamCreation"]</li>
                </ul>
            </TmCard>
        </div>
    </div>

    @if (_features.Count > 0)
    {
        <section class="feature-availability-section" data-testid="premium-feature-availability">
            <div class="section-heading">
                <h2>@L["FeatureAvailability_Title"]</h2>
                <p>@L["FeatureAvailability_Description"]</p>
            </div>
            <div class="feature-availability-grid">
                @foreach (var feature in _features)
                {
                    <div class="feature-availability-item @(feature.IsAvailable ? "unlocked" : "locked")"
                         data-testid="@(feature.IsAvailable ? "premium-feature-unlocked" : "premium-feature-locked")"
                         title="@GetFeatureTooltip(feature)">
                        <TmIcon Name="@(feature.IsAvailable ? IconNames.CheckCircle : IconNames.Lock)" />
                        <span>@feature.Description</span>
                        <strong>@(feature.IsAvailable ? L["Feature_Unlocked"] : L["Feature_Locked"])</strong>
                    </div>
                }
            </div>
        </section>
    }

    <div class="pricing-section">
        <h2 class="pricing-title">@L["ChoosePlan"]</h2>
        <div class="pricing-grid" data-testid="premium-pricing-grid">
            <div class="pricing-card-wrapper" data-testid="premium-plan-monthly">
                <TmCard Class="pricing-card">
                    <div class="pricing-header">
                        <h3>@L["Tab_Monthly"]</h3>
                        <div class="price">
                            <span class="amount">99</span>
                            <span class="currency">Kč</span>
                            <span class="period">/@L["Period_Month"]</span>
                        </div>
                    </div>
                    <ul class="pricing-features">
                        <li>@L["Feature_AllPremium"]</li>
                        <li>@L["Feature_MonthlyBilling"]</li>
                        <li>@L["Feature_CancelAnytime"]</li>
                    </ul>
                    <div data-testid="premium-subscribe-monthly">
                        <TmButton Variant="ButtonVariant.Secondary"
                                  OnClick="() => Subscribe(SubscriptionPlan.Monthly)"
                                  IsLoading="_isLoadingMonthly"
                                  Disabled="_status?.IsActive == true">
                            @(_status?.Plan == SubscriptionPlan.Monthly ? L["Button_Current"] : L["Button_Subscribe"])
                        </TmButton>
                    </div>
                </TmCard>
            </div>

            <div class="pricing-card-wrapper" data-testid="premium-plan-yearly">
                <TmCard Class="pricing-card featured">
                    <div data-testid="premium-best-value">
                        <TmBadge Variant="BadgeVariant.Warning" Class="best-value-badge">
                            @L["BestValue"]
                        </TmBadge>
                    </div>
                    <div class="pricing-header">
                        <h3>@L["Tab_Yearly"]</h3>
                        <div class="price">
                            <span class="amount">899</span>
                            <span class="currency">Kč</span>
                            <span class="period">/@L["Period_Year"]</span>
                        </div>
                        <div class="savings">
                            <span class="original-price">1 188 Kč</span>
                            <span class="save-badge">@L["Save25Percent"]</span>
                        </div>
                    </div>
                    <ul class="pricing-features">
                        <li>@L["Feature_AllPremium"]</li>
                        <li>@L["Feature_SaveMoney"]</li>
                        <li>@L["Feature_PrioritySupport"]</li>
                    </ul>
                    <div data-testid="premium-subscribe-yearly">
                        <TmButton Variant="ButtonVariant.Primary"
                                  OnClick="() => Subscribe(SubscriptionPlan.Yearly)"
                                  IsLoading="_isLoadingYearly"
                                  Disabled="_status?.IsActive == true">
                            @(_status?.Plan == SubscriptionPlan.Yearly ? L["Button_Current"] : L["Button_Subscribe"])
                        </TmButton>
                    </div>
                </TmCard>
            </div>

            <div class="pricing-card-wrapper" data-testid="premium-plan-lifetime">
                <TmCard Class="pricing-card">
                    <div class="pricing-header">
                        <h3>@L["Tab_Lifetime"]</h3>
                        <div class="price">
                            <span class="amount">2 499</span>
                            <span class="currency">Kč</span>
                            <span class="period">@L["Period_Onetime"]</span>
                        </div>
                    </div>
                    <ul class="pricing-features">
                        <li>@L["Feature_AllPremium"]</li>
                        <li>@L["Feature_Forever"]</li>
                        <li>@L["Feature_FutureUpdates"]</li>
                    </ul>
                    <div data-testid="premium-subscribe-lifetime">
                        <TmButton Variant="ButtonVariant.Secondary"
                                  OnClick="() => Subscribe(SubscriptionPlan.Lifetime)"
                                  IsLoading="_isLoadingLifetime"
                                  Disabled="_status?.IsActive == true">
                            @(_status?.Plan == SubscriptionPlan.Lifetime ? L["Button_Current"] : L["Button_Buy"])
                        </TmButton>
                    </div>
                </TmCard>
            </div>
        </div>
    </div>

    <div class="payment-info">
        <div class="payment-methods">
            <TmIcon Name="@IconNames.Lock" />
            <span>@L["SecurePayment"]</span>
        </div>
        <div class="cancel-notice">
            <TmIcon Name="@IconNames.Info" />
            <span>@L["CancelAnytime"]</span>
        </div>
    </div>
</div>

@code {
    private PremiumStatusDto? _status;
    private IReadOnlyList<PremiumFeatureDto> _features = [];
    private bool _isLoadingMonthly;
    private bool _isLoadingYearly;
    private bool _isLoadingLifetime;
    private bool _isCancelling;

    protected override async Task OnInitializedAsync()
    {
        await LoadPremiumStateAsync();
    }

    private async Task LoadPremiumStateAsync()
    {
        try
        {
            var statusTask = PremiumService.GetStatusAsync();
            _status = statusTask == null ? null : await statusTask;
        }
        catch
        {
            ToastService.ShowError(L["Error_StatusLoad"]);
        }

        try
        {
            var featuresTask = PremiumService.GetFeaturesAsync();
            _features = featuresTask == null ? [] : await featuresTask;
        }
        catch
        {
            ToastService.ShowError(L["Error_FeaturesLoad"]);
            _features = [];
        }
    }

    private async Task Subscribe(SubscriptionPlan plan)
    {
        if (_status?.IsActive == true)
            return;

        SetLoading(plan, true);

        try
        {
            var response = await PremiumService.CreateCheckoutAsync(plan);
            if (!string.IsNullOrEmpty(response.StripeCheckoutUrl))
            {
                NavigationManager.NavigateTo(response.StripeCheckoutUrl);
            }
        }
        catch
        {
            ToastService.ShowError(L["Error_CheckoutCreate"]);
        }
        finally
        {
            SetLoading(plan, false);
        }
    }

    private async Task CancelSubscriptionAsync()
    {
        _isCancelling = true;

        try
        {
            var cancelled = await PremiumService.CancelSubscriptionAsync();
            if (cancelled)
            {
                ToastService.ShowSuccess(L["CancelSubscription_Success"]);
                await LoadPremiumStateAsync();
            }
            else
            {
                ToastService.ShowError(L["CancelSubscription_Failed"]);
            }
        }
        finally
        {
            _isCancelling = false;
        }
    }

    private string GetPlanLabel(SubscriptionPlan? plan)
    {
        return plan.HasValue
            ? L[$"Plan_{plan.Value}"].Value
            : L["Status_Free"].Value;
    }

    private string GetFeatureTooltip(PremiumFeatureDto feature)
    {
        return feature.IsAvailable
            ? L["Feature_UnlockedTooltip"].Value
            : L["Feature_LockedTooltip"].Value;
    }

    private void SetLoading(SubscriptionPlan plan, bool loading)
    {
        switch (plan)
        {
            case SubscriptionPlan.Monthly:
                _isLoadingMonthly = loading;
                break;
            case SubscriptionPlan.Yearly:
                _isLoadingYearly = loading;
                break;
            case SubscriptionPlan.Lifetime:
                _isLoadingLifetime = loading;
                break;
        }
    }
}
