@page "/profile"
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Shop
@using LexiQuest.Shared.DTOs.Users
@inject IStringLocalizer<Profile> L
@inject IUserService UserService
@inject IShopService ShopService

<PageTitle>@L["Profile_PageTitle"]</PageTitle>

<div class="profile-page" data-testid="profile-page">
    <div class="profile-container">
        <h1 class="profile-heading" data-testid="profile-heading">@L["Profile_Title"]</h1>

        @if (_isLoading)
        {
            <div class="profile-loading" data-testid="profile-loading">
                <TmSkeleton Type="Rectangle" Height="200px" />
                <TmSkeleton Type="Rectangle" Height="300px" />
            </div>
        }
        else if (_profile == null)
        {
            <TmEmptyState
                Icon="alert-circle"
                Title="@L["Profile_LoadError"]"
                Description="@L["Profile_LoadErrorDescription"]" />
        }
        else
        {
            <div class="profile-stack">
                <!-- User Info Section -->
                <div data-testid="profile-summary-card">
                    <TmCard Variant="CardVariant.Elevated">
                        <div class="profile-card-content profile-summary">
                            <div class="@GetAvatarFrameClass()" data-testid="profile-avatar-frame">
                                <TmAvatar Src="@_profile.AvatarUrl" Alt="@_profile.Username" Size="AvatarSize.Lg" />
                            </div>
                            <div class="profile-summary-copy">
                                <h2>@_profile.Username</h2>
                                <p class="profile-email">@_profile.Email</p>
                                <p class="profile-member-since">
                                    @L["Profile_MemberSince", _profile.CreatedAt.ToString("dd.MM.yyyy")]
                                </p>
                                @if (_profile.IsPremium)
                                {
                                    <div class="profile-premium-badge" data-testid="profile-premium-badge">
                                        <TmBadge Variant="BadgeVariant.Success">
                                            @L["Profile_PremiumBadge"] - @GetPremiumPlanLabel(_profile.PremiumPlan)
                                        </TmBadge>
                                    </div>
                                }
                                @if (HasEquippedCosmetics)
                                {
                                    <div class="profile-equipped-cosmetics" data-testid="profile-equipped-cosmetics">
                                        <span class="profile-equipped-label">@L["Profile_EquippedItems"]</span>
                                        @if (EquippedFrame != null)
                                        {
                                            <span class="profile-equipped-pill" data-testid="profile-equipped-frame">
                                                <TmIcon Name="square" />
                                                @_equippedFrame!.ShopItemName
                                            </span>
                                        }
                                        @if (EquippedTheme != null)
                                        {
                                            <span class="profile-equipped-pill" data-testid="profile-equipped-theme">
                                                <TmIcon Name="palette" />
                                                @_equippedTheme!.ShopItemName
                                            </span>
                                        }
                                        @if (EquippedBoost != null)
                                        {
                                            <span class="profile-equipped-pill" data-testid="profile-equipped-boost">
                                                <TmIcon Name="zap" />
                                                @_equippedBoost!.ShopItemName
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </TmCard>
                </div>

                <!-- Stats Section -->
                <div data-testid="profile-stats-card">
                    <TmCard Variant="CardVariant.Elevated">
                        <div class="profile-card-content">
                            <h2 class="profile-card-title">@L["Profile_StatsTitle"]</h2>
                            <div class="profile-stats-grid">
                                <div class="profile-stat" data-testid="profile-stat-level">
                                    <div class="profile-stat-icon profile-stat-icon-level">
                                        <TmIcon Name="@IconNames.Star" />
                                    </div>
                                    <div class="profile-stat-value">@_profile.Stats.Level</div>
                                    <div class="profile-stat-label">@L["Profile_Level"]</div>
                                </div>

                                <div class="profile-stat" data-testid="profile-stat-xp">
                                    <div class="profile-stat-icon profile-stat-icon-xp">
                                        <TmIcon Name="@IconNames.Zap" />
                                    </div>
                                    <div class="profile-stat-value">@_profile.Stats.TotalXP.ToString("N0")</div>
                                    <div class="profile-stat-label">@L["Profile_TotalXP"]</div>
                                </div>

                                <div class="profile-stat" data-testid="profile-stat-words">
                                    <div class="profile-stat-icon profile-stat-icon-words">
                                        <TmIcon Name="@IconNames.FileText" />
                                    </div>
                                    <div class="profile-stat-value">@_profile.Stats.WordsSolved.ToString("N0")</div>
                                    <div class="profile-stat-label">@L["Profile_WordsSolved"]</div>
                                </div>

                                <div class="profile-stat" data-testid="profile-stat-current-streak">
                                    <div class="profile-stat-icon profile-stat-icon-current-streak">
                                        <TmIcon Name="@IconNames.Fire" />
                                    </div>
                                    <div class="profile-stat-value">@_profile.Stats.CurrentStreak</div>
                                    <div class="profile-stat-label">@L["Profile_CurrentStreak"]</div>
                                </div>

                                <div class="profile-stat" data-testid="profile-stat-longest-streak">
                                    <div class="profile-stat-icon profile-stat-icon-longest-streak">
                                        <TmIcon Name="@IconNames.Trophy" />
                                    </div>
                                    <div class="profile-stat-value">@_profile.Stats.LongestStreak</div>
                                    <div class="profile-stat-label">@L["Profile_LongestStreak"]</div>
                                </div>

                                <div class="profile-stat" data-testid="profile-stat-accuracy">
                                    <div class="profile-stat-icon profile-stat-icon-accuracy">
                                        <TmIcon Name="@IconNames.Target" />
                                    </div>
                                    <div class="profile-stat-value">@($"{_profile.Stats.Accuracy:N0}%")</div>
                                    <div class="profile-stat-label">@L["Profile_Accuracy"]</div>
                                </div>
                            </div>
                        </div>
                    </TmCard>
                </div>

                <!-- Achievements Section -->
                <div data-testid="profile-achievements-card">
                    <TmCard Variant="CardVariant.Elevated">
                        <div class="profile-card-content">
                            <div class="profile-achievements-heading">
                                <h2 class="profile-card-title">@L["Profile_AchievementsTitle"]</h2>
                                <a class="profile-achievements-link"
                                   href="/achievements"
                                   data-testid="profile-achievements-link"
                                   aria-label="@L["Profile_AchievementsLink"]">
                                    <TmIcon Name="@IconNames.Trophy" />
                                    <span>@L["Profile_AchievementsLink"]</span>
                                </a>
                            </div>
                            <p class="profile-achievements-description">@L["Profile_AchievementsDescription"]</p>
                        </div>
                    </TmCard>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool _isLoading = true;
    private UserProfileDto? _profile;
    private List<UserInventoryItemDto> _equippedItems = [];
    private UserInventoryItemDto? _equippedFrame;
    private UserInventoryItemDto? _equippedTheme;
    private UserInventoryItemDto? _equippedBoost;

    private UserInventoryItemDto? EquippedFrame => _equippedFrame;
    private UserInventoryItemDto? EquippedTheme => _equippedTheme;
    private UserInventoryItemDto? EquippedBoost => _equippedBoost;
    private bool HasEquippedCosmetics => EquippedFrame != null || EquippedTheme != null || EquippedBoost != null;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _isLoading = true;
        try
        {
            await LoadEquippedItemsAsync();
            _profile = await UserService.GetProfileAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadEquippedItemsAsync()
    {
        try
        {
            _equippedItems = (await ShopService.GetUserInventoryAsync())
                .Where(item => item.IsEquipped)
                .ToList();
        }
        catch
        {
            _equippedItems = [];
        }

        _equippedFrame = GetEquippedItem("Frame");
        _equippedTheme = GetEquippedItem("Theme");
        _equippedBoost = GetEquippedItem("Boost");
    }

    private string GetPremiumPlanLabel(string? plan)
    {
        return plan switch
        {
            "Monthly" => L["Profile_PremiumPlanMonthly"].Value,
            "Yearly" => L["Profile_PremiumPlanYearly"].Value,
            "Lifetime" => L["Profile_PremiumPlanLifetime"].Value,
            _ => plan ?? L["Profile_PremiumPlanUnknown"].Value
        };
    }

    private UserInventoryItemDto? GetEquippedItem(string category)
    {
        return _equippedItems.FirstOrDefault(item =>
            item.ShopItemCategory.Equals(category, StringComparison.OrdinalIgnoreCase));
    }

    private string GetAvatarFrameClass()
    {
        var classes = "profile-avatar-frame";
        if (EquippedFrame != null)
        {
            classes += $" profile-avatar-frame--{GetFrameVariant(EquippedFrame.ShopItemName)}";
        }

        return classes;
    }

    private static string GetFrameVariant(string frameName)
    {
        if (frameName.Contains("Stříbr", StringComparison.OrdinalIgnoreCase))
        {
            return "silver";
        }

        if (frameName.Contains("Dřev", StringComparison.OrdinalIgnoreCase))
        {
            return "wood";
        }

        return "default";
    }
}
