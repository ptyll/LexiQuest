@page "/daily-challenge"
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Game
@using LexiQuest.Shared.Enums
@inject IDailyChallengeService DailyChallengeService
@inject IStringLocalizer<DailyChallenge> L
@inject NavigationManager NavigationManager

<div class="daily-challenge-page" data-testid="daily-page">
    @if (isLoading)
    {
        <div class="loading-state">
            <TmSkeleton Type="Rectangle" Height="200px" />
            <TmSkeleton Type="Rectangle" Height="300px" />
        </div>
    }
    else if (challenge == null)
    {
        <div class="empty-state">
            <TmEmptyState
                Icon="calendar"
                Title="@L["EmptyState.Title"]"
                Description="@L["EmptyState.Description"]" />
        </div>
    }
    else if (isCompleted)
    {
        <div class="completed-state" data-testid="daily-completed-state">
            <TmCard>
                <div class="completed-content">
                    <TmIcon Name="check-circle" Class="completed-icon" />
                    <h2>@L["Completed.Title"]</h2>
                    <p>@L["Completed.Message"]</p>

                    @if (result != null)
                    {
                        <div class="result-stats">
                            <div class="stat">
                                <span class="stat-label">@L["Result.Time"]</span>
                                <span class="stat-value" data-testid="daily-result-time">@FormatTime(result.TimeTaken)</span>
                            </div>
                            <div class="stat">
                                <span class="stat-label">@L["Result.XP"]</span>
                                <span class="stat-value" data-testid="daily-result-xp">+@result.XPEarned</span>
                            </div>
                            <div class="stat">
                                <span class="stat-label">@L["Result.Rank"]</span>
                                <span class="stat-value" data-testid="daily-result-rank">#@result.Rank</span>
                            </div>
                        </div>
                    }
                </div>
            </TmCard>
        </div>
    }
    else
    {
        <div class="challenge-header" data-testid="daily-challenge-card">
            <TmCard>
                <div class="header-content">
                    <div class="modifier-badge @GetModifierClass(challenge.Modifier)" data-testid="daily-modifier">
                        <TmIcon Name="@GetModifierIcon(challenge.Modifier)" />
                        <span>@GetModifierName(challenge.Modifier)</span>
                    </div>
                    <h1>@L["Challenge.Title"]</h1>
                    <p class="modifier-desc">@challenge.ModifierDescription</p>
                    <div class="xp-multiplier">
                        <TmIcon Name="star" />
                        <span>@L["XPBonus", challenge.XPMultiplier]</span>
                    </div>
                </div>
            </TmCard>
        </div>

        @if (!isStarted)
        {
            <div class="challenge-actions">
                <button class="tm-btn tm-btn--primary" type="button" data-testid="daily-start" @onclick="StartChallenge">
                    @L["Button.Play"]
                </button>
            </div>
        }
        else
        {
            <div class="daily-play-panel" data-testid="daily-play-panel">
                <TmCard>
                    <div class="daily-play-content">
                        <div class="scrambled-word" data-testid="daily-scrambled-word">@challenge.ScrambledWord</div>
                        <div class="word-length">@L["Play.WordLength", challenge.WordLength]</div>
                        <label class="answer-field">
                            <span>@L["Play.Answer"]</span>
                            <input data-testid="daily-answer-input"
                                   value="@answer"
                                   @oninput="HandleAnswerInput"
                                   maxlength="50"
                                   autocomplete="off" />
                        </label>
                        @if (!string.IsNullOrWhiteSpace(submitError))
                        {
                            <div class="submit-error" data-testid="daily-submit-error">@submitError</div>
                        }
                        <button class="tm-btn tm-btn--primary"
                                type="button"
                                data-testid="daily-submit"
                                disabled="@isSubmitting"
                                @onclick="SubmitChallenge">
                            @L["Button.Submit"]
                        </button>
                    </div>
                </TmCard>
            </div>
        }
    }

    @if (challenge != null)
    {
        <div class="leaderboard-section">
            <h2>@L["Leaderboard.Title"]</h2>
            <div class="leaderboard" data-testid="daily-leaderboard">
                @if (leaderboard.Count == 0)
                {
                    <div class="leaderboard-empty" data-testid="daily-leaderboard-empty">
                        @L["Leaderboard.Empty"]
                    </div>
                }
                else
                {
                    @foreach (var entry in leaderboard)
                    {
                        <div class="leaderboard-row @(entry.IsCurrentUser ? "is-current-user" : "")" data-testid="daily-leaderboard-row">
                            <span class="rank">#@entry.Rank</span>
                            <span class="username">@entry.Username</span>
                            <span class="time">@FormatTime(entry.TimeTaken)</span>
                            <span class="xp">@entry.XPEarned XP</span>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private DailyChallengeDto? challenge;
    private List<DailyLeaderboardEntryDto> leaderboard = new();
    private ChallengeResultDto? result;
    private bool isLoading = true;
    private bool isCompleted = false;
    private bool isStarted;
    private bool isSubmitting;
    private DateTime startedAtUtc;
    private string answer = string.Empty;
    private string? submitError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        challenge = await DailyChallengeService.GetTodayAsync();
        leaderboard = await DailyChallengeService.GetLeaderboardAsync();
        isCompleted = await DailyChallengeService.HasCompletedTodayAsync();

        if (isCompleted)
        {
            var currentUserEntry = leaderboard.FirstOrDefault(e => e.IsCurrentUser);
            if (currentUserEntry != null)
            {
                result = new ChallengeResultDto(
                    IsCorrect: true,
                    CorrectAnswer: string.Empty,
                    XPEarned: currentUserEntry.XPEarned,
                    TimeTaken: currentUserEntry.TimeTaken,
                    Rank: currentUserEntry.Rank
                );
            }
        }

        isLoading = false;
    }

    private void StartChallenge()
    {
        isStarted = true;
        startedAtUtc = DateTime.UtcNow;
        submitError = null;
    }

    private async Task SubmitChallenge()
    {
        if (challenge == null || string.IsNullOrWhiteSpace(answer))
        {
            submitError = L["Error.EmptyAnswer"].Value;
            return;
        }

        isSubmitting = true;
        submitError = null;

        try
        {
            var elapsed = DateTime.UtcNow - startedAtUtc;
            if (elapsed < TimeSpan.FromSeconds(1))
            {
                elapsed = TimeSpan.FromSeconds(1);
            }

            var submitResult = await DailyChallengeService.SubmitAnswerAsync(answer, elapsed);
            if (submitResult == null)
            {
                submitError = L["Error.SubmitFailed"].Value;
                return;
            }

            if (!submitResult.IsCorrect)
            {
                submitError = L["Error.WrongAnswer", submitResult.CorrectAnswer].Value;
                return;
            }

            result = submitResult;
            isCompleted = true;
            isStarted = false;
            leaderboard = await DailyChallengeService.GetLeaderboardAsync();
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void HandleAnswerInput(ChangeEventArgs args)
    {
        answer = args.Value?.ToString() ?? string.Empty;
    }

    private string GetModifierClass(DailyModifier modifier) => $"modifier-{modifier.ToString().ToLower()}";

    private string GetModifierIcon(DailyModifier modifier) => modifier switch
    {
        DailyModifier.Speed => "zap",
        DailyModifier.Hard => "shield",
        DailyModifier.NoHints => "eye-off",
        DailyModifier.DoubleLetters => "type",
        DailyModifier.Team => "users",
        DailyModifier.Category => "tag",
        _ => "star"
    };

    private string GetModifierName(DailyModifier modifier) => L[$"Modifier.{modifier}"].Value;

    private static string FormatTime(TimeSpan time)
    {
        if (time <= TimeSpan.Zero)
            return "0s";

        var totalSeconds = Math.Max(1, (int)Math.Ceiling(time.TotalSeconds));
        if (totalSeconds < 60)
            return $"{totalSeconds}s";

        return $"{totalSeconds / 60}:{totalSeconds % 60:D2}";
    }
}
