@page "/password-reset/{Token}"
@using LexiQuest.Blazor.Services
@inject IAuthService AuthService
@inject IStringLocalizer<PasswordResetConfirm> L
@inject NavigationManager NavigationManager

<div class="password-reset-container">
    <div class="password-reset-card">
        <h2 class="password-reset-title">@L["Title"]</h2>
        <p class="password-reset-subtitle">@L["Subtitle"]</p>

        @if (isSuccess)
        {
            <div class="alert alert-success">
                @L["Success.Message"]
            </div>
            <a href="/login" class="btn btn-primary btn-block">@L["Button.Login"]</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-error">
                    @errorMessage
                </div>
            }

            <EditForm Model="@model" OnValidSubmit="HandleSubmit" FormName="passwordResetConfirmForm">
                <FluentValidationValidator />
                
                <div class="form-field">
                    <label for="newPassword">@L["Input.NewPassword.Label"]</label>
                    <InputText 
                        id="newPassword"
                        type="password"
                        @bind-Value="model.NewPassword" 
                        placeholder="@L["Input.NewPassword.Placeholder"]" />
                    <ValidationMessage For="@(() => model.NewPassword)" />
                </div>

                <div class="form-field">
                    <label for="confirmPassword">@L["Input.ConfirmPassword.Label"]</label>
                    <InputText 
                        id="confirmPassword"
                        type="password"
                        @bind-Value="model.ConfirmPassword" 
                        placeholder="@L["Input.ConfirmPassword.Placeholder"]" />
                    <ValidationMessage For="@(() => model.ConfirmPassword)" />
                </div>

                <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>Loading...</span>
                    }
                    else
                    {
                        @L["Button.Submit"]
                    }
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private ResetPasswordModel model = new();
    private bool isLoading;
    private bool isSuccess;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        model.Token = Token;
    }

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.ResetPasswordAsync(Token, model.NewPassword, model.ConfirmPassword);
            
            if (result?.Success == true)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? L["Error.General"];
            }
        }
        catch
        {
            errorMessage = L["Error.General"];
        }
        finally
        {
            isLoading = false;
        }
    }

    public class ResetPasswordModel
    {
        public string Token { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
