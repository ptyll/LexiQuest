@page "/password-reset/{Token}"
@layout LandingLayout
@using LexiQuest.Blazor.Services
@inject IAuthService AuthService
@inject IStringLocalizer<PasswordResetConfirm> L
@inject NavigationManager NavigationManager

<div class="password-reset-page" data-testid="password-reset-confirm-page">
    <TmCard Variant="CardVariant.Elevated" Class="password-reset-card">
        <div class="password-reset-header">
            <div class="password-reset-brand">LexiQuest</div>
            <h1 class="password-reset-title">@L["Title"]</h1>
            <p class="password-reset-subtitle">@L["Subtitle"]</p>
        </div>

        @if (isSuccess)
        {
            <TmAlert Severity="AlertSeverity.Success" Class="password-reset-alert">
                @L["Success.Message"]
            </TmAlert>
            <a href="/login" class="password-reset-primary-link">@L["Button.Login"]</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <TmAlert Severity="AlertSeverity.Error" Class="password-reset-alert">
                    @errorMessage
                </TmAlert>
            }

            <EditForm Model="@model" OnValidSubmit="HandleSubmit" FormName="passwordResetConfirmForm" data-testid="password-reset-confirm-form" novalidate>
                <FluentValidationValidator />

                <div class="password-reset-form-fields">
                    <div class="password-reset-field">
                        <label for="newPassword">@L["Input.NewPassword.Label"]</label>
                        <InputText
                            id="newPassword"
                            class="password-reset-input"
                            type="password"
                            @bind-Value="model.NewPassword"
                            placeholder="@L["Input.NewPassword.Placeholder"]" />
                        <ValidationMessage For="@(() => model.NewPassword)" />
                    </div>

                    <div class="password-reset-field">
                        <label for="confirmPassword">@L["Input.ConfirmPassword.Label"]</label>
                        <InputText
                            id="confirmPassword"
                            class="password-reset-input"
                            type="password"
                            @bind-Value="model.ConfirmPassword"
                            placeholder="@L["Input.ConfirmPassword.Placeholder"]" />
                        <ValidationMessage For="@(() => model.ConfirmPassword)" />
                    </div>
                </div>

                <span data-testid="password-reset-confirm-submit">
                    <TmButton Type="ButtonType.Submit"
                              Variant="ButtonVariant.Primary"
                              Block="true"
                              IsLoading="isLoading"
                              LoadingText="@L["Button.Loading"]"
                              Class="password-reset-submit-btn">
                        @L["Button.Submit"]
                    </TmButton>
                </span>
            </EditForm>
        }
    </TmCard>
</div>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private ResetPasswordModel model = new();
    private bool isLoading;
    private bool isSuccess;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        model.Token = Token;
    }

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.ResetPasswordAsync(Token, model.NewPassword, model.ConfirmPassword);
            
            if (result?.Success == true)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? L["Error.General"];
            }
        }
        catch
        {
            errorMessage = L["Error.General"];
        }
        finally
        {
            isLoading = false;
        }
    }

    public class ResetPasswordModel
    {
        public string Token { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
