@page "/password-reset"
@layout LandingLayout
@using LexiQuest.Blazor.Services
@inject IAuthService AuthService
@inject IStringLocalizer<PasswordResetRequest> L
@inject NavigationManager NavigationManager

<div class="password-reset-page" data-testid="password-reset-request-page">
    <TmCard Variant="CardVariant.Elevated" Class="password-reset-card">
        <div class="password-reset-header">
            <div class="password-reset-brand">LexiQuest</div>
            <h1 class="password-reset-title">@L["Title"]</h1>
            <p class="password-reset-subtitle">@L["Subtitle"]</p>
        </div>

        @if (isSuccess)
        {
            <TmAlert Severity="AlertSeverity.Success" Class="password-reset-alert">
                @L["Success.Message"]
            </TmAlert>
            <a href="/login" class="password-reset-primary-link">@L["Link.BackToLogin"]</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <TmAlert Severity="AlertSeverity.Error" Class="password-reset-alert">
                    @errorMessage
                </TmAlert>
            }

            <EditForm Model="@model" OnValidSubmit="HandleSubmit" FormName="passwordResetRequestForm" data-testid="password-reset-request-form" novalidate>
                <FluentValidationValidator />

                <div class="password-reset-form-fields">
                    <div class="password-reset-field">
                        <label for="email">@L["Input.Email.Label"]</label>
                        <InputText
                            id="email"
                            class="password-reset-input"
                            type="email"
                            @bind-Value="model.Email"
                            placeholder="@L["Input.Email.Placeholder"]" />
                        <ValidationMessage For="@(() => model.Email)" />
                    </div>
                </div>

                <span data-testid="password-reset-request-submit">
                    <TmButton Type="ButtonType.Submit"
                              Variant="ButtonVariant.Primary"
                              Block="true"
                              IsLoading="isLoading"
                              LoadingText="@L["Button.Loading"]"
                              Class="password-reset-submit-btn">
                        @L["Button.Submit"]
                    </TmButton>
                </span>
            </EditForm>

            <div class="password-reset-links">
                <a href="/login">@L["Link.BackToLogin"]</a>
            </div>
        }
    </TmCard>
</div>

@code {
    private RequestPasswordResetModel model = new();
    private bool isLoading;
    private bool isSuccess;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.RequestPasswordResetAsync(model.Email);
            
            if (result?.Success == true)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? L["Error.General"];
            }
        }
        catch
        {
            errorMessage = L["Error.General"];
        }
        finally
        {
            isLoading = false;
        }
    }

    public class RequestPasswordResetModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
