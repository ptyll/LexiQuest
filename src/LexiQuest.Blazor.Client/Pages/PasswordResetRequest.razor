@page "/password-reset"
@using LexiQuest.Blazor.Services
@inject IAuthService AuthService
@inject IStringLocalizer<PasswordResetRequest> L
@inject NavigationManager NavigationManager

<div class="password-reset-container">
    <div class="password-reset-card">
        <h2 class="password-reset-title">@L["Title"]</h2>
        <p class="password-reset-subtitle">@L["Subtitle"]</p>

        @if (isSuccess)
        {
            <div class="alert alert-success">
                @L["Success.Message"]
            </div>
            <a href="/login" class="btn btn-primary btn-block">@L["Link.BackToLogin"]</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-error">
                    @errorMessage
                </div>
            }

            <EditForm Model="@model" OnValidSubmit="HandleSubmit" FormName="passwordResetRequestForm">
                <FluentValidationValidator />
                
                <div class="form-field">
                    <label for="email">@L["Input.Email.Label"]</label>
                    <InputText 
                        id="email"
                        type="email"
                        @bind-Value="model.Email" 
                        placeholder="@L["Input.Email.Placeholder"]" />
                    <ValidationMessage For="@(() => model.Email)" />
                </div>

                <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>Loading...</span>
                    }
                    else
                    {
                        @L["Button.Submit"]
                    }
                </button>
            </EditForm>

            <div class="password-reset-links">
                <a href="/login">@L["Link.BackToLogin"]</a>
            </div>
        }
    </div>
</div>

@code {
    private RequestPasswordResetModel model = new();
    private bool isLoading;
    private bool isSuccess;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.RequestPasswordResetAsync(model.Email);
            
            if (result?.Success == true)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? L["Error.General"];
            }
        }
        catch
        {
            errorMessage = L["Error.General"];
        }
        finally
        {
            isLoading = false;
        }
    }

    public class RequestPasswordResetModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
