@page "/admin"
@using LexiQuest.Shared.DTOs.Admin
@inject IStringLocalizer<AdminDashboard> L
@inject NavigationManager NavigationManager
@inject IAdminService AdminService
@inject ToastService ToastService

<PageTitle>@L["Title"] - LexiQuest</PageTitle>

<div class="admin-dashboard-page" data-testid="admin-dashboard-page">
    <div class="admin-header">
        <h1>@L["Title"]</h1>
        <p>@L["Subtitle"]</p>
    </div>

    @if (_isLoading)
    {
        <div class="stats-grid">
            <TmSkeleton Variant="SkeletonVariant.Rect" Height="120px" />
            <TmSkeleton Variant="SkeletonVariant.Rect" Height="120px" />
            <TmSkeleton Variant="SkeletonVariant.Rect" Height="120px" />
            <TmSkeleton Variant="SkeletonVariant.Rect" Height="120px" />
        </div>
    }
    else if (_stats != null)
    {
        <div class="stats-grid" data-testid="admin-dashboard-stats">
            <div class="admin-stat-card" data-testid="admin-stat-total-users" data-value="@_stats.TotalUsers">
                <div class="admin-stat-value">@_stats.TotalUsers</div>
                <div class="admin-stat-copy">
                    <div class="admin-stat-title">@L["Stat.TotalUsers"]</div>
                    <div class="admin-stat-subtitle">@L["Stat.TotalUsers.Sub"]</div>
                </div>
            </div>

            <div class="admin-stat-card" data-testid="admin-stat-active-today" data-value="@_stats.ActiveToday">
                <div class="admin-stat-value">@_stats.ActiveToday</div>
                <div class="admin-stat-copy">
                    <div class="admin-stat-title">@L["Stat.ActiveToday"]</div>
                    <div class="admin-stat-subtitle">@L["Stat.ActiveToday.Sub"]</div>
                </div>
            </div>

            <div class="admin-stat-card" data-testid="admin-stat-total-words" data-value="@_stats.TotalWords">
                <div class="admin-stat-value">@_stats.TotalWords</div>
                <div class="admin-stat-copy">
                    <div class="admin-stat-title">@L["Stat.TotalWords"]</div>
                    <div class="admin-stat-subtitle">@L["Stat.TotalWords.Sub"]</div>
                </div>
            </div>

            <div class="admin-stat-card" data-testid="admin-stat-daily-challenges" data-value="@_stats.DailyChallenges">
                <div class="admin-stat-value">@_stats.DailyChallenges</div>
                <div class="admin-stat-copy">
                    <div class="admin-stat-title">@L["Stat.DailyChallenges"]</div>
                    <div class="admin-stat-subtitle">@L["Stat.DailyChallenges.Sub"]</div>
                </div>
            </div>
        </div>

        <div class="quick-links">
            <TmCard Variant="CardVariant.Elevated"
                    Header="@L["QuickLinks.Title"]"
                    HeaderIcon="@IconNames.Zap">
                <div class="link-buttons">
                    <span data-testid="admin-link-words">
                        <TmButton Variant="ButtonVariant.Primary"
                                  OnClick="NavigateToWords"
                                  Icon="@IconNames.FileText">
                            @L["QuickLinks.Words"]
                        </TmButton>
                    </span>
                    <span data-testid="admin-link-users">
                        <TmButton Variant="ButtonVariant.Secondary"
                                  OnClick="NavigateToUsers"
                                  Icon="@IconNames.Users">
                            @L["QuickLinks.Users"]
                        </TmButton>
                    </span>
                </div>
            </TmCard>
        </div>
    }
    else if (_loadError)
    {
        <TmAlert Severity="AlertSeverity.Error">
            @L["Error.LoadFailed"]
        </TmAlert>
        <div class="retry-container">
            <TmButton Variant="ButtonVariant.Primary" OnClick="LoadStatsAsync">
                @L["Button.Retry"]
            </TmButton>
        </div>
    }
</div>

@code {
    private AdminDashboardStatsDto? _stats;
    private bool _isLoading = true;
    private bool _loadError;

    protected override async Task OnInitializedAsync()
    {
        var isAdmin = await AdminService.IsCurrentUserAdminAsync();
        if (!isAdmin)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        _isLoading = true;
        _loadError = false;
        StateHasChanged();

        try
        {
            _stats = await AdminService.GetDashboardStatsAsync();
            if (_stats == null)
            {
                _loadError = true;
            }
        }
        catch
        {
            _loadError = true;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void NavigateToWords()
    {
        NavigationManager.NavigateTo("/admin/words");
    }

    private void NavigateToUsers()
    {
        NavigationManager.NavigateTo("/admin/users");
    }
}
