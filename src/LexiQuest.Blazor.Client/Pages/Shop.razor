@page "/shop"
@using LexiQuest.Blazor.Components.Shop
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Shop
@inject IShopService ShopService
@inject IPremiumService PremiumService
@inject IStringLocalizer<Shop> L
@inject IToastService ToastService
@inject NavigationManager NavigationManager

<PageTitle>@L["Title"] - LexiQuest</PageTitle>

<div class="shop-page" data-testid="shop-page">
    <div class="shop-header">
        <div class="header-content">
            <h1 class="page-title">@L["Title"]</h1>
            <p class="page-subtitle">@L["Subtitle"]</p>
        </div>
        <div class="coin-balance" data-testid="shop-coin-balance">
            <TmBadge Variant="BadgeVariant.Warning" Icon="@IconNames.Star">
                @L["Coins_Balance"] @UserCoins
            </TmBadge>
        </div>
    </div>

    <nav class="shop-tabs" data-testid="shop-tabs" aria-label="@L["Title"]">
        <button type="button" class="@GetCategoryClass("")" data-testid="shop-tab-all" @onclick='() => SetCategory("")'>@L["Tab_All"]</button>
        <button type="button" class="@GetCategoryClass("Avatar")" data-testid="shop-tab-avatar" @onclick='() => SetCategory("Avatar")'>@L["Tab_Avatars"]</button>
        <button type="button" class="@GetCategoryClass("Frame")" data-testid="shop-tab-frame" @onclick='() => SetCategory("Frame")'>@L["Tab_Frames"]</button>
        <button type="button" class="@GetCategoryClass("Theme")" data-testid="shop-tab-theme" @onclick='() => SetCategory("Theme")'>@L["Tab_Themes"]</button>
        <button type="button" class="@GetCategoryClass("Boost")" data-testid="shop-tab-boost" @onclick='() => SetCategory("Boost")'>@L["Tab_Boosts"]</button>
    </nav>

    @if (!FilteredItems.Any())
    {
        <div class="shop-empty">
            @L["Empty_Category"]
        </div>
    }
    else
    {
        <div class="shop-grid">
            @foreach (var item in FilteredItems)
            {
                <ShopItemCard
                    Item="item"
                    IsOwned="IsItemOwned(item.Id)"
                    IsEquipped="IsItemEquipped(item.Id)"
                    IsPremium="IsPremium"
                    OnPurchase="() => PurchaseItem(item)"
                    OnEquip="() => EquipItem(item.Id)" />
            }
        </div>
    }
</div>

@code {
    private List<ShopItemDto> AllItems { get; set; } = new();
    private List<UserInventoryItemDto> UserInventory { get; set; } = new();
    private int UserCoins { get; set; }
    private bool IsPremium { get; set; }
    private string ActiveCategory { get; set; } = "";

    private IEnumerable<ShopItemDto> FilteredItems =>
        string.IsNullOrEmpty(ActiveCategory)
            ? AllItems
            : AllItems.Where(i => i.Category == ActiveCategory);

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var itemsTask = ShopService.GetShopItemsAsync();
            var inventoryTask = ShopService.GetUserInventoryAsync();
            var coinsTask = ShopService.GetUserCoinsAsync();
            var premiumTask = PremiumService.IsPremiumAsync();

            await Task.WhenAll(itemsTask, inventoryTask, coinsTask, premiumTask);

            AllItems = (await itemsTask).ToList();
            UserInventory = (await inventoryTask).ToList();
            UserCoins = await coinsTask;
            IsPremium = await premiumTask;
        }
        catch
        {
            ToastService.ShowError(L["Load_Error"]);
        }
    }

    private bool IsItemOwned(Guid itemId)
    {
        return UserInventory.Any(i => i.ShopItemId == itemId);
    }

    private bool IsItemEquipped(Guid itemId)
    {
        return UserInventory.Any(i => i.ShopItemId == itemId && i.IsEquipped);
    }

    private async Task PurchaseItem(ShopItemDto item)
    {
        if (item.IsPremiumOnly && !IsPremium)
        {
            ToastService.ShowWarning(L["Premium_Required"], () =>
            {
                NavigationManager.NavigateTo("/premium");
            });
            return;
        }

        try
        {
            var result = await ShopService.PurchaseItemAsync(item.Id);
            if (result.Success)
            {
                UserCoins = result.RemainingCoins;
                await LoadDataAsync(); // Refresh inventory
                ToastService.ShowSuccess(L["Purchase_Success"]);
            }
            else
            {
                ToastService.ShowError(result.ErrorMessage ?? L["Purchase_Error"]);
            }
        }
        catch
        {
            ToastService.ShowError(L["Purchase_Error"]);
        }
    }

    private async Task EquipItem(Guid itemId)
    {
        try
        {
            var inventoryItem = UserInventory.FirstOrDefault(i => i.ShopItemId == itemId);
            if (inventoryItem == null) return;

            var result = await ShopService.EquipItemAsync(inventoryItem.Id);
            if (result.Success)
            {
                await LoadDataAsync(); // Refresh to update equipped status
                ToastService.ShowSuccess(L["Equip_Success"]);
            }
            else
            {
                ToastService.ShowError(result.ErrorMessage ?? L["Equip_Error"]);
            }
        }
        catch
        {
            ToastService.ShowError(L["Equip_Error"]);
        }
    }

    private void SetCategory(string category)
    {
        ActiveCategory = category;
    }

    private string GetCategoryClass(string category)
    {
        return ActiveCategory == category ? "shop-tab active" : "shop-tab";
    }
}
