@page "/register"
@using LexiQuest.Blazor.Models
@using LexiQuest.Blazor.Services
@using LexiQuest.Blazor.Validators
@using Tempo.Blazor
@using Tempo.Blazor.FluentValidation
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Register> L

<div class="register-container">
    <div class="register-card-wrapper">
        <TmCard Variant="CardVariant.Elevated" Class="register-card">
            <div class="register-header">
                <div class="logo-container">
                    <span class="logo-text">LexiQuest</span>
                </div>
                <h1 class="register-title">@L["Title"]</h1>
                <p class="register-subtitle">@L["Subtitle"]</p>
            </div>

            <EditForm Model="_model" OnValidSubmit="HandleRegister">
                <FluentValidationValidator />
                
                <div class="form-fields">
                    <TmFormField Label="@L["Input.Email.Label"]">
                        <TmTextInput 
                            @bind-Value="_model.Email" 
                            Placeholder="@L["Input.Email.Placeholder"]"
                            Type="email"
                            autocomplete="email" />
                    </TmFormField>
                    <ValidationMessage For="() => _model.Email" />

                    <TmFormField Label="@L["Input.Username.Label"]">
                        <TmTextInput 
                            @bind-Value="_model.Username" 
                            Placeholder="@L["Input.Username.Placeholder"]"
                            autocomplete="username" />
                    </TmFormField>
                    <ValidationMessage For="() => _model.Username" />

                    <TmFormField Label="@L["Input.Password.Label"]">
                        <TmTextInput 
                            @bind-Value="_model.Password" 
                            Placeholder="@L["Input.Password.Placeholder"]"
                            Type="password"
                            autocomplete="new-password" />
                    </TmFormField>
                    <TmPasswordStrengthIndicator Password="@_model.Password" />
                    <ValidationMessage For="() => _model.Password" />

                    <TmFormField Label="@L["Input.ConfirmPassword.Label"]">
                        <TmTextInput 
                            @bind-Value="_model.ConfirmPassword" 
                            Placeholder="@L["Input.ConfirmPassword.Placeholder"]"
                            Type="password"
                            autocomplete="new-password" />
                    </TmFormField>
                    <ValidationMessage For="() => _model.ConfirmPassword" />

                    <div class="terms-checkbox">
                        <TmCheckbox 
                            @bind-Value="_model.AcceptTerms" 
                            Label="@L["Input.Terms.Label"]" />
                    </div>
                    <ValidationMessage For="() => _model.AcceptTerms" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <TmAlert Severity="AlertSeverity.Error" Class="error-alert">
                        @_errorMessage
                    </TmAlert>
                }

                <TmButton 
                    Variant="ButtonVariant.Primary" 
                    ButtonType="ButtonType.Submit"
                    IsLoading="_isLoading"
                    Block="true"
                    Class="submit-button">
                    @L["Button.Submit"]
                </TmButton>

                <div class="google-button-wrapper">
                    <TmButton 
                        Variant="ButtonVariant.Outline" 
                        Block="true"
                        Class="google-button">
                        @L["Button.Google"]
                    </TmButton>
                </div>
            </EditForm>

            <div class="login-link-wrapper">
                <span>@L["Link.Login.Text"]</span>
                <a href="/login" class="login-link">@L["Link.Login"]</a>
            </div>
        </TmCard>
    </div>
</div>

@code {
    private RegisterModel _model = new();
    private bool _isLoading = false;
    private string? _errorMessage;

    private async Task HandleRegister()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await AuthService.RegisterAsync(_model);

            if (result.Success)
            {
                NavigationManager.NavigateTo("/dashboard");
            }
            else
            {
                _errorMessage = result.ErrorMessage;
            }
        }
        finally
        {
            _isLoading = false;
        }
    }
}
