@page "/login"
@using LexiQuest.Blazor.Models
@using LexiQuest.Blazor.Services
@using LexiQuest.Blazor.Validators
@using FluentValidation
@inject IAuthService AuthService
@inject IStringLocalizer<Login> L
@inject NavigationManager NavigationManager

<div class="login-page">
    <TmCard Variant="CardVariant.Elevated" Class="login-card">
        <div class="login-header">
            <h1 class="login-brand">LexiQuest</h1>
            <h2 class="login-title">@L["Title"]</h2>
            <p class="login-subtitle">@L["Subtitle"]</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <TmAlert Severity="AlertSeverity.Error"
                     Title="@L["Alert.ErrorTitle"]"
                     Dismissable="true"
                     OnDismiss="ClearError"
                     Class="login-alert">
                @errorMessage
            </TmAlert>
        }

        <EditForm Model="@model" OnValidSubmit="HandleLogin" FormName="loginForm">
            <FluentValidationValidator />

            <div class="login-form-fields">
                <TmValidatedField Label="@L["Input.Email.Label"]"
                                  Placeholder="@L["Input.Email.Placeholder"]"
                                  Type="email"
                                  Required="true"
                                  AutoComplete="email"
                                  @bind-Value="model.Email" />

                <TmValidatedField Label="@L["Input.Password.Label"]"
                                  Placeholder="@L["Input.Password.Placeholder"]"
                                  Type="password"
                                  Required="true"
                                  AutoComplete="current-password"
                                  @bind-Value="model.Password" />

                <TmCheckbox @bind-Value="model.RememberMe"
                            Label="@L["Input.RememberMe.Label"]" />
            </div>

            <TmButton Type="ButtonType.Submit"
                      Variant="ButtonVariant.Primary"
                      Block="true"
                      IsLoading="isLoading"
                      LoadingText="@L["Button.Loading"]"
                      Class="login-submit-btn">
                @L["Button.Submit"]
            </TmButton>
        </EditForm>

        <div class="login-links">
            <TmButton Variant="ButtonVariant.Link"
                      OnClick="NavigateToPasswordReset"
                      Class="login-forgot-link">
                @L["Link.ForgotPassword"]
            </TmButton>
        </div>

        <div class="login-divider">
            <span>@L["Divider.Or"]</span>
        </div>

        <TmButton Variant="ButtonVariant.Outline"
                  Block="true"
                  OnClick="HandleGoogleLogin"
                  Disabled="isLoading"
                  Class="login-google-btn">
            <TmIcon Name="@IconNames.ExternalLink" Class="google-icon" />
            @L["Button.Google"]
        </TmButton>

        <div class="login-register-prompt">
            <span>@L["Link.Register.Text"]</span>
            <TmButton Variant="ButtonVariant.Link"
                      OnClick="NavigateToRegister"
                      Class="login-register-link">
                @L["Link.Register"]
            </TmButton>
        </div>
    </TmCard>
</div>

@code {
    private LoginModel model = new();
    private bool isLoading;
    private string? errorMessage;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await AuthService.LoginAsync(model.Email, model.Password, model.RememberMe);

            if (result?.Success == true)
            {
                NavigationManager.NavigateTo("/dashboard");
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? L["Error.InvalidCredentials"];
            }
        }
        catch (Exception ex)
        {
            errorMessage = L["Error.InvalidCredentials"];
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HandleGoogleLogin()
    {
        var redirectUrl = NavigationManager.ToAbsoluteUri("/auth/google-challenge").ToString();
        NavigationManager.NavigateTo($"/api/v1/users/google-login?redirectUri={Uri.EscapeDataString(redirectUrl)}", forceLoad: true);
    }

    private void NavigateToPasswordReset()
    {
        NavigationManager.NavigateTo("/password-reset");
    }

    private void NavigateToRegister()
    {
        NavigationManager.NavigateTo("/register");
    }

    private void ClearError()
    {
        errorMessage = null;
    }
}
