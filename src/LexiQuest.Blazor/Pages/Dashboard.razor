@page "/dashboard"
@using LexiQuest.Blazor.Components.Stats
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Game
@inject IStringLocalizer<Dashboard> L
@inject NavigationManager NavigationManager

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>@L["Title"]</h1>
        <p>@L["Welcome"]</p>
    </div>

    @if (isLoading)
    {
        <div class="dashboard-loading">
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
        </div>
    }
    else if (stats != null)
    {
        <div class="stats-grid">
            <div class="stat-card stat-xp">
                <span class="stat-icon">⭐</span>
                <div class="stat-info">
                    <span class="stat-value">@stats.TotalXP</span>
                    <span class="stat-label">@L["Stat.XP"]</span>
                </div>
            </div>

            <div class="stat-card stat-streak">
                <span class="stat-icon">🔥</span>
                <div class="stat-info">
                    <span class="stat-value">@stats.CurrentStreak</span>
                    <span class="stat-label">@L["Stat.Streak"]</span>
                </div>
            </div>

            <div class="stat-card stat-accuracy">
                <span class="stat-icon">🎯</span>
                <div class="stat-info">
                    <span class="stat-value">@stats.Accuracy%</span>
                    <span class="stat-label">@L["Stat.Accuracy"]</span>
                </div>
            </div>

            <div class="stat-card stat-time">
                <span class="stat-icon">⏱️</span>
                <div class="stat-info">
                    <span class="stat-value">@stats.AverageTime</span>
                    <span class="stat-label">@L["Stat.AvgTime"]</span>
                </div>
            </div>
        </div>

        <div class="dashboard-sections">
            <div class="section daily-challenge">
                <h3>@L["DailyChallenge.Title"]</h3>
                <button class="btn btn-primary" @onclick="StartDailyChallenge">
                    @L["DailyChallenge.Play"]
                </button>
            </div>

            <div class="section quick-actions">
                <h3>@L["QuickActions.Title"]</h3>
                <div class="action-buttons">
                    <button class="btn btn-secondary" @onclick='() => NavigateTo("/game")'>
                        @L["Action.Training"]
                    </button>
                    <button class="btn btn-secondary" @onclick='() => NavigateTo("/paths")'>
                        @L["Action.Paths"]
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private UserStatsSummary? stats;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        isLoading = true;
        try
        {
            // Load stats from API
            await Task.Delay(100); // Placeholder
            stats = new UserStatsSummary(
                TotalXP: 1250,
                CurrentLevel: 5,
                CurrentStreak: 7,
                LongestStreak: 14,
                Accuracy: 85,
                AverageTime: "12s",
                TotalWordsSolved: 45
            );
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartDailyChallenge()
    {
        NavigationManager.NavigateTo("/game/daily");
    }

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
    }

    public record UserStatsSummary(
        int TotalXP,
        int CurrentLevel,
        int CurrentStreak,
        int LongestStreak,
        double Accuracy,
        string AverageTime,
        int TotalWordsSolved
    );
}
