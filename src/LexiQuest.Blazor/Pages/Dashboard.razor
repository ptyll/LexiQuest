@page "/dashboard"
@using LexiQuest.Blazor.Components.Stats
@using LexiQuest.Blazor.Services
@using LexiQuest.Shared.DTOs.Game
@inject IStringLocalizer<Dashboard> L
@inject NavigationManager NavigationManager
@inject IUserService UserService
@inject IStatsService StatsService

<div class="dashboard-page">
    <div class="dashboard-header">
        <h1>@L["Title"]</h1>
        <p>@L["Welcome"]</p>
    </div>

    @if (isLoading)
    {
        <div class="dashboard-skeleton">
            <TmSkeleton Variant="SkeletonVariant.Rect" Height="120px" />
            <TmSkeleton Variant="SkeletonVariant.Rect" Height="120px" />
            <TmSkeleton Variant="SkeletonVariant.Rect" Height="120px" />
            <TmSkeleton Variant="SkeletonVariant.Rect" Height="120px" />
        </div>
    }
    else if (stats != null)
    {
        <div class="stats-grid">
            <TmStatCard Title="@L["Stat.XP"]"
                        Value="@stats.TotalXP.ToString()"
                        Icon="@IconNames.Star"
                        SubValue="@($"{L["Stat.Level"]} {stats.CurrentLevel}")"
                        SubValueColor="var(--tm-color-primary)" />

            <TmStatCard Title="@L["Stat.Streak"]"
                        Value="@stats.CurrentStreak.ToString()"
                        Icon="@IconNames.TrendingUp"
                        SubValue="@($"Nejdelší: {stats.LongestStreak}")"
                        SubValueColor="var(--tm-color-warning)" />

            <TmStatCard Title="@L["Stat.Accuracy"]"
                        Value="@($"{stats.Accuracy}%")"
                        Icon="@IconNames.Target"
                        SubValue="@($"{stats.TotalWordsSolved} {GetWordsLabel(stats.TotalWordsSolved)}")"
                        SubValueColor="var(--tm-color-success)" />

            <TmStatCard Title="@L["Stat.AvgTime"]"
                        Value="@stats.AverageTime"
                        Icon="@IconNames.Clock"
                        SubValue="na slovo"
                        SubValueColor="var(--tm-color-text-secondary)" />
        </div>

        <div class="dashboard-sections">
            <TmCard Variant="CardVariant.Default"
                    Header="@L["DailyChallenge.Title"]"
                    HeaderIcon="@IconNames.Calendar"
                    Class="daily-challenge-card">
                <TmButton Variant="ButtonVariant.Primary"
                          OnClick="StartDailyChallenge"
                          Icon="@IconNames.Play">
                    @L["DailyChallenge.Play"]
                </TmButton>
            </TmCard>

            <TmCard Variant="CardVariant.Default"
                    Header="@L["QuickActions.Title"]"
                    HeaderIcon="@IconNames.Zap"
                    Class="quick-actions-card">
                <div class="action-buttons">
                    <TmButton Variant="ButtonVariant.Secondary"
                              OnClick='() => NavigateTo("/game")'
                              Icon="@IconNames.Play">
                        @L["Action.Training"]
                    </TmButton>
                    <TmButton Variant="ButtonVariant.Secondary"
                              OnClick='() => NavigateTo("/paths")'
                              Icon="@IconNames.Map">
                        @L["Action.Paths"]
                    </TmButton>
                </div>
            </TmCard>
        </div>
    }
    else if (loadError)
    {
        <TmEmptyState Icon="@IconNames.AlertCircle"
                      Title="@L["Error.LoadTitle"]"
                      Description="@L["Error.LoadDescription"]"
                      ActionText="@L["Button.Retry"]"
                      OnAction="LoadStatsAsync" />
    }
</div>

@code {
    private UserStatsDto? stats;
    private bool isLoading = true;
    private bool loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            stats = await StatsService.GetUserStatsAsync();
        }
        catch
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void StartDailyChallenge()
    {
        NavigationManager.NavigateTo("/daily-challenge");
    }

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
    }

    private string GetWordsLabel(int count)
    {
        if (count == 1) return "slovo";
        if (count >= 2 && count <= 4) return "slova";
        return "slov";
    }
}
