@page "/register"
@using LexiQuest.Blazor.Models
@using LexiQuest.Blazor.Services
@using LexiQuest.Blazor.Validators
@using FluentValidation
@inject IAuthService AuthService
@inject IStringLocalizer<Register> L
@inject NavigationManager NavigationManager

<div class="register-page">
    <TmCard Variant="CardVariant.Elevated" Class="register-card">
        <div class="register-header">
            <h1 class="register-brand">LexiQuest</h1>
            <h2 class="register-title">@L["Title"]</h2>
            <p class="register-subtitle">@L["Subtitle"]</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <TmAlert Severity="AlertSeverity.Error"
                     Title="@L["Alert.ErrorTitle"]"
                     Dismissable="true"
                     OnDismiss="ClearError"
                     Class="register-alert">
                @errorMessage
            </TmAlert>
        }

        <EditForm Model="@model" OnValidSubmit="HandleRegister" FormName="registerForm">
            <FluentValidationValidator />

            <div class="register-form-fields">
                <TmValidatedField Label="@L["Input.Email.Label"]"
                                  Placeholder="@L["Input.Email.Placeholder"]"
                                  Type="email"
                                  Required="true"
                                  AutoComplete="email"
                                  @bind-Value="model.Email" />

                <TmValidatedField Label="@L["Input.Username.Label"]"
                                  Placeholder="@L["Input.Username.Placeholder"]"
                                  Type="text"
                                  Required="true"
                                  AutoComplete="username"
                                  @bind-Value="model.Username" />

                <div class="password-field-group">
                    <TmValidatedField Label="@L["Input.Password.Label"]"
                                      Placeholder="@L["Input.Password.Placeholder"]"
                                      Type="password"
                                      Required="true"
                                      AutoComplete="new-password"
                                      @bind-Value="model.Password" />

                    <TmPasswordStrengthIndicator Password="@model.Password"
                                                  Class="password-strength" />
                </div>

                <TmValidatedField Label="@L["Input.ConfirmPassword.Label"]"
                                  Placeholder="@L["Input.ConfirmPassword.Placeholder"]"
                                  Type="password"
                                  Required="true"
                                  AutoComplete="new-password"
                                  @bind-Value="model.ConfirmPassword" />

                <TmCheckbox @bind-Value="model.AcceptTerms"
                            Label="@L["Input.Terms.Label"]"
                            Required="true" />
            </div>

            <TmButton Type="ButtonType.Submit"
                      Variant="ButtonVariant.Primary"
                      Block="true"
                      IsLoading="isLoading"
                      LoadingText="@L["Button.Loading"]"
                      Class="register-submit-btn">
                @L["Button.Submit"]
            </TmButton>
        </EditForm>

        <div class="register-divider">
            <span>@L["Divider.Or"]</span>
        </div>

        <TmButton Variant="ButtonVariant.Outline"
                  Block="true"
                  OnClick="HandleGoogleRegister"
                  Disabled="isLoading"
                  Class="register-google-btn">
            <TmIcon Name="@IconNames.ExternalLink" Class="google-icon" />
            @L["Button.Google"]
        </TmButton>

        <div class="register-login-prompt">
            <span>@L["Link.Login.Text"]</span>
            <TmButton Variant="ButtonVariant.Link"
                      OnClick="NavigateToLogin"
                      Class="register-login-link">
                @L["Link.Login"]
            </TmButton>
        </div>
    </TmCard>
</div>

@code {
    private RegisterModel model = new();
    private bool isLoading;
    private string? errorMessage;

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await AuthService.RegisterAsync(model);

            if (result?.Success == true)
            {
                NavigationManager.NavigateTo("/dashboard");
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? L["Error.RegistrationFailed"];
            }
        }
        catch (Exception ex)
        {
            errorMessage = L["Error.RegistrationFailed"];
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HandleGoogleRegister()
    {
        var redirectUrl = NavigationManager.ToAbsoluteUri("/auth/google-callback").ToString();
        NavigationManager.NavigateTo($"/api/v1/users/google-register?redirectUri={Uri.EscapeDataString(redirectUrl)}", forceLoad: true);
    }

    private void NavigateToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }

    private void ClearError()
    {
        errorMessage = null;
    }
}
