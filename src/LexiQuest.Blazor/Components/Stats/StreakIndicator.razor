@using LexiQuest.Shared.DTOs.Streak
@inject IStringLocalizer<StreakIndicator> L

<div class="streak-indicator @GetFireLevelClass()">
    <div class="streak-main">
        <div class="streak-flames">
            @for (int i = 0; i < GetFireCount(); i++)
            {
                <span class="flame">🔥</span>
            }
        </div>
        <div class="streak-info">
            <span class="streak-days">@GetStreakText()</span>
            @if (IsAtRisk)
            {
                <span class="streak-risk">⚠️ @L["AtRisk"]</span>
            }
        </div>
    </div>

    @if (TimeRemaining.HasValue)
    {
        <div class="streak-timer">
            @L["TimeRemaining"]: @TimeRemaining.Value.ToString("hh\\:mm")
        </div>
    }

    <!-- Shield Management Section -->
    @if (ShieldProtection != null)
    {
        <div class="shield-management">
            <!-- Active Shield -->
            @if (ShieldProtection.HasActiveShield)
            {
                <div class="shield-active">
                    <span class="shield-icon">🛡️</span>
                    <span class="shield-text">@L["ShieldActive"]</span>
                </div>
            }
            <!-- Available Shields -->
            else if (ShieldProtection.ShieldsRemaining > 0)
            {
                <div class="shield-available">
                    <span class="shield-icon">🛡️</span>
                    <span class="shield-count">@ShieldProtection.ShieldsRemaining @L["ShieldsRemaining"]</span>
                </div>
            }
            <!-- Free Shield Available -->
            else if (ShieldProtection.CanActivateFreeShield)
            {
                <button class="shield-activate-btn tm-btn tm-btn--primary tm-btn--sm" @onclick="OnActivateShield">
                    <span>🛡️</span>
                    <span>@L["ActivateShield"]</span>
                    <span class="shield-badge">@L["FreeShieldAvailable"]</span>
                </button>
            }
            <!-- Premium Shield Available (for premium users) -->
            else if (IsPremium && ShieldProtection.NextShieldAvailableAt.HasValue)
            {
                @if (GetDaysUntilNextShield() <= 0)
                {
                    <button class="shield-activate-btn tm-btn tm-btn--primary tm-btn--sm" @onclick="OnActivateShield">
                        <span>🛡️</span>
                        <span>@L["ActivateShield"]</span>
                        <span class="shield-badge premium">@L["PremiumShieldAvailable"]</span>
                    </button>
                }
                else
                {
                    <div class="shield-countdown">
                        <span>🛡️</span>
                        <span>@L["NextShieldAvailable"]: @GetDaysUntilNextShield() @L["Days"]</span>
                    </div>
                }
            }
            <!-- Buy Shields Option -->
            else if (OnBuyShields.HasDelegate)
            {
                <button class="buy-shields-btn tm-btn tm-btn--outline tm-btn--sm" @onclick="OnBuyShields">
                    <span>🛡️</span>
                    <span>@L["BuyShields"]</span>
                </button>
            }

            <!-- Freeze Badge (Premium) -->
            @if (IsPremium && !ShieldProtection.FreezeUsedThisWeek)
            {
                <div class="freeze-badge">
                    <span>❄️</span>
                    <span>@L["FreezeAvailable"]</span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public int CurrentDays { get; set; }

    [Parameter]
    public string FireLevel { get; set; } = "Cold";

    [Parameter]
    public TimeSpan? TimeRemaining { get; set; }

    [Parameter]
    public bool IsAtRisk { get; set; }

    [Parameter]
    public bool IsPremium { get; set; }

    [Parameter]
    public StreakProtectionDto? ShieldProtection { get; set; }

    [Parameter]
    public EventCallback OnActivateShield { get; set; }

    [Parameter]
    public EventCallback OnBuyShields { get; set; }

    private string GetFireLevelClass()
    {
        return FireLevel.ToLower() switch
        {
            "cold" => "streak-cold",
            "small" => "streak-small",
            "medium" => "streak-medium",
            "large" => "streak-large",
            "legendary" => "streak-legendary",
            _ => "streak-cold"
        };
    }

    private int GetFireCount()
    {
        return FireLevel.ToLower() switch
        {
            "cold" => 0,
            "small" => 1,
            "medium" => 2,
            "large" => 3,
            "legendary" => 5,
            _ => 0
        };
    }

    private string GetStreakText()
    {
        return CurrentDays == 1 ? $"1 {L["StreakDays"]}" : $"{CurrentDays} {L["StreakDays"]}";
    }

    private int GetDaysUntilNextShield()
    {
        if (ShieldProtection?.NextShieldAvailableAt.HasValue != true)
            return 0;
        return (ShieldProtection.NextShieldAvailableAt.Value - DateTime.UtcNow).Days;
    }
}
