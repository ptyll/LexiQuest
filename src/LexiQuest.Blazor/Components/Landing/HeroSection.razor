@inject IStringLocalizer<HeroSection> L
@inject NavigationManager NavigationManager

<section class="hero-section" data-testid="hero-section">
    <div class="hero-container">
        <!-- Logo -->
        <div class="hero-logo" data-testid="hero-logo">
            <TmIcon Name="sparkles" Size="IconSize.Xl" Class="hero-logo-icon" />
            <span class="hero-logo-text">LexiQuest</span>
        </div>

        <!-- Tagline -->
        <h1 class="hero-tagline" data-testid="hero-tagline">
            @L["Hero.Tagline"]
        </h1>

        <!-- Subtitle -->
        <p class="hero-subtitle" data-testid="hero-subtitle">
            @L["Hero.Subtitle"]
        </p>

        <!-- CTA Buttons -->
        <div class="hero-cta">
            <div data-testid="hero-cta-register">
                <TmButton Variant="ButtonVariant.Primary"
                          Size="ButtonSize.Lg"
                          OnClick="NavigateToRegister">
                    @L["Hero.CTA.Register"]
                </TmButton>
            </div>
            <div data-testid="hero-cta-guest">
                <TmButton Variant="ButtonVariant.Outline"
                          Size="ButtonSize.Lg"
                          OnClick="NavigateToGuest">
                    @L["Hero.CTA.TryFree"]
                </TmButton>
            </div>
        </div>

        <!-- Social Proof -->
        <div class="hero-social-proof" data-testid="hero-social-proof">
            <TmIcon Name="users" Size="IconSize.Sm" />
            <span>@L["Hero.SocialProof"]</span>
        </div>

        <!-- Animated Demo -->
        <div class="hero-demo">
            <div class="demo-card">
                <div class="demo-scrambled">
                    @ScrambledWord
                </div>
                <div class="demo-hint">
                    <TmIcon Name="lightbulb" Size="IconSize.Sm" />
                    <span>@DemoHint</span>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public EventCallback OnRegisterClick { get; set; }

    [Parameter]
    public EventCallback OnGuestClick { get; set; }

    private string ScrambledWord { get; set; } = "S L O V O";
    private string DemoHint { get; set; } = "4 písmena";

    protected override void OnInitialized()
    {
        _ = AnimateDemoAsync();
    }

    private async Task AnimateDemoAsync()
    {
        while (true)
        {
            await Task.Delay(5000);
            // Animation cycle would happen here
            await InvokeAsync(StateHasChanged);
        }
    }

    private void NavigateToRegister()
    {
        if (OnRegisterClick.HasDelegate)
        {
            OnRegisterClick.InvokeAsync();
        }
        else
        {
            NavigationManager.NavigateTo("/register");
        }
    }

    private void NavigateToGuest()
    {
        if (OnGuestClick.HasDelegate)
        {
            OnGuestClick.InvokeAsync();
        }
        else
        {
            NavigationManager.NavigateTo("/play");
        }
    }
}