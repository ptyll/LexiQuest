@using Microsoft.Extensions.Localization
@inject IStringLocalizer<GameTimer> L
@implements IAsyncDisposable

<div class="game-timer @GetTimerClass()">
    <div class="timer-bar-container">
        <div class="timer-bar" style="width: @GetProgressPercentage()%"></div>
    </div>
    <div class="timer-text">
        @string.Format(L["TimeRemaining"], TimeSpan.FromSeconds(RemainingSeconds).ToString("mm\\:ss"))
    </div>
</div>

@code {
    [Parameter] public int TotalSeconds { get; set; } = 30;
    [Parameter] public int RemainingSeconds { get; set; } = 30;
    [Parameter] public EventCallback OnTimeUp { get; set; }
    [Parameter] public bool IsPaused { get; set; } = false;

    private System.Timers.Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += OnTimerElapsed;
        _timer.AutoReset = true;
        _timer.Start();
    }

    private void OnTimerElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        if (IsPaused) return;

        InvokeAsync(async () =>
        {
            if (RemainingSeconds > 0)
            {
                RemainingSeconds--;
                StateHasChanged();

                if (RemainingSeconds == 0)
                {
                    await OnTimeUp.InvokeAsync();
                }
            }
        });
    }

    private double GetProgressPercentage()
    {
        if (TotalSeconds <= 0) return 0;
        return (RemainingSeconds / (double)TotalSeconds) * 100;
    }

    private string GetTimerClass()
    {
        var percentage = GetProgressPercentage();
        return percentage switch
        {
            <= 15 => "timer-critical",
            <= 35 => "timer-warning",
            _ => "timer-normal"
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (_timer != null)
        {
            _timer.Elapsed -= OnTimerElapsed;
            _timer.Stop();
            _timer.Dispose();
            _timer = null;
        }
    }
}
