@inject IStringLocalizer<Pages.Multiplayer> Localizer

<TmModal 
    Show="@IsVisible" 
    Title="@Localizer["Room_Join_Title"]"
    Size="ModalSize.Small"
    OnClose="OnClose"
    Class="join-room-modal">
    
    <ChildContent>
        <EditForm Model="@this" OnValidSubmit="HandleSubmit" class="join-room-form">
            <DataAnnotationsValidator />
            
            <TmFormField Label="@Localizer["Room_Code_Label"]">
                <input type="text"
                    value="@RoomCode"
                    placeholder="@Localizer["Room_Code_Placeholder"]"
                    maxlength="10"
                    autofocus
                    aria-label="@Localizer["Room_Code_Label"]"
                    autocomplete="off"
                    class="room-code-input tm-input"
                    @oninput="HandleInput" />
                @if (!string.IsNullOrEmpty(_validationMessage))
                {
                    <div class="validation-message">@_validationMessage</div>
                }
            </TmFormField>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <TmAlert Severity="AlertSeverity.Error" Class="error-alert">
                    @ErrorMessage
                </TmAlert>
            }
        </EditForm>
    </ChildContent>

    <Footer>
        <button class="join-button tm-btn tm-btn-primary"
                @onclick="HandleSubmit"
                disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner"></span>
            }
            @Localizer["Button_Join"]
        </button>
        <button class="cancel-button tm-btn"
                @onclick="OnClose">
            @Localizer["Button_Cancel"]
        </button>
    </Footer>
</TmModal>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<string> OnJoin { get; set; }

    public string RoomCode { get; set; } = "";

    private string? _validationMessage;

    private void HandleInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        // Auto uppercase and limit length
        RoomCode = value.ToUpperInvariant()[..Math.Min(value.Length, 10)];
        _validationMessage = null;
    }

    private async Task HandleSubmit()
    {
        _validationMessage = null;

        if (string.IsNullOrWhiteSpace(RoomCode))
        {
            _validationMessage = Localizer["Validation_RoomCode_Required"];
            StateHasChanged();
            return;
        }

        // Validate format
        var regex = new System.Text.RegularExpressions.Regex(@"^LEXIQ-[A-Z0-9]{4}$");
        if (!regex.IsMatch(RoomCode))
        {
            _validationMessage = Localizer["Validation_RoomCode_InvalidFormat"];
            StateHasChanged();
            return;
        }

        await OnJoin.InvokeAsync(RoomCode);
    }
}
