@inject INotificationService NotificationService
@inject IStringLocalizer<NotificationBell> Localizer
@inject NavigationManager Navigation
@implements IDisposable

<div class="notification-bell-container">
    <TmButton Variant="ButtonVariant.Ghost" OnClick="ToggleDropdown" CssClass="bell-button">
        <span class="bell-icon">&#128276;</span>
        @if (_unreadCount > 0)
        {
            <TmBadge Color="BadgeColor.Danger" CssClass="unread-badge">@_unreadCount</TmBadge>
        }
    </TmButton>

    @if (_isOpen)
    {
        <div class="notification-dropdown">
            <div class="dropdown-header">
                <h3 class="dropdown-title">@Localizer["Title"]</h3>
                @if (_unreadCount > 0)
                {
                    <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" OnClick="HandleMarkAllRead" CssClass="mark-all-read-button">
                        @Localizer["MarkAllRead"]
                    </TmButton>
                }
            </div>

            <div class="dropdown-body">
                @if (!_notifications.Any())
                {
                    <div class="empty-state">
                        <TmAlert Severity="AlertSeverity.Info">@Localizer["NoNotifications"]</TmAlert>
                    </div>
                }
                else
                {
                    @foreach (var group in GetGroupedNotifications())
                    {
                        <div class="notification-group">
                            <div class="group-label">@group.Key</div>
                            @foreach (var notification in group.Value)
                            {
                                <div class="notification-item @(notification.IsRead ? "" : "unread")" @onclick="() => HandleNotificationClick(notification)">
                                    <div class="notification-icon">@GetTypeIcon(notification.Type)</div>
                                    <div class="notification-content">
                                        <div class="notification-title">@notification.Title</div>
                                        <div class="notification-message">@notification.Message</div>
                                        <div class="notification-time">@FormatTime(notification.CreatedAt)</div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(notification.ActionUrl))
                                    {
                                        <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" OnClick="() => NavigateTo(notification.ActionUrl)" CssClass="notification-action">
                                            &#8594;
                                        </TmButton>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _isOpen;
    private int _unreadCount;
    private List<LexiQuest.Shared.DTOs.Notifications.NotificationDto> _notifications = [];
    private Timer? _pollingTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadUnreadCount();
        _pollingTimer = new Timer(async _ =>
        {
            await LoadUnreadCount();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadUnreadCount()
    {
        _unreadCount = await NotificationService.GetUnreadCountAsync();
    }

    private async Task LoadNotifications()
    {
        _notifications = await NotificationService.GetNotificationsAsync();
    }

    private async Task ToggleDropdown()
    {
        _isOpen = !_isOpen;
        if (_isOpen)
        {
            await LoadNotifications();
        }
    }

    private async Task HandleMarkAllRead()
    {
        await NotificationService.MarkAllReadAsync();
        _unreadCount = 0;
        foreach (var n in _notifications)
        {
            // Refresh list to reflect read state
        }
        _notifications = await NotificationService.GetNotificationsAsync();
    }

    private async Task HandleNotificationClick(LexiQuest.Shared.DTOs.Notifications.NotificationDto notification)
    {
        if (!notification.IsRead)
        {
            await NotificationService.MarkReadAsync(notification.Id);
            _unreadCount = Math.Max(0, _unreadCount - 1);
            await LoadNotifications();
        }

        if (!string.IsNullOrEmpty(notification.ActionUrl))
        {
            Navigation.NavigateTo(notification.ActionUrl);
        }
    }

    private void NavigateTo(string url)
    {
        Navigation.NavigateTo(url);
    }

    private Dictionary<string, List<LexiQuest.Shared.DTOs.Notifications.NotificationDto>> GetGroupedNotifications()
    {
        var today = DateTime.UtcNow.Date;
        var yesterday = today.AddDays(-1);
        var weekAgo = today.AddDays(-7);

        var groups = new Dictionary<string, List<LexiQuest.Shared.DTOs.Notifications.NotificationDto>>();

        var todayItems = _notifications.Where(n => n.CreatedAt.Date == today).ToList();
        var yesterdayItems = _notifications.Where(n => n.CreatedAt.Date == yesterday).ToList();
        var thisWeekItems = _notifications.Where(n => n.CreatedAt.Date < yesterday && n.CreatedAt.Date >= weekAgo).ToList();
        var olderItems = _notifications.Where(n => n.CreatedAt.Date < weekAgo).ToList();

        if (todayItems.Any()) groups[Localizer["Today"]] = todayItems;
        if (yesterdayItems.Any()) groups[Localizer["Yesterday"]] = yesterdayItems;
        if (thisWeekItems.Any()) groups[Localizer["ThisWeek"]] = thisWeekItems;
        if (olderItems.Any()) groups[Localizer["Older"]] = olderItems;

        return groups;
    }

    private static string GetTypeIcon(LexiQuest.Shared.Enums.NotificationType type) => type switch
    {
        LexiQuest.Shared.Enums.NotificationType.StreakWarning => "\u26a0\ufe0f",
        LexiQuest.Shared.Enums.NotificationType.StreakLost => "\U0001f494",
        LexiQuest.Shared.Enums.NotificationType.DailyChallenge => "\U0001f3af",
        LexiQuest.Shared.Enums.NotificationType.LeagueUpdate => "\U0001f3c6",
        LexiQuest.Shared.Enums.NotificationType.AchievementUnlocked => "\u2b50",
        LexiQuest.Shared.Enums.NotificationType.Milestone => "\U0001f389",
        LexiQuest.Shared.Enums.NotificationType.SystemMessage => "\U0001f4e2",
        _ => "\U0001f514"
    };

    private static string FormatTime(DateTime createdAt)
    {
        var diff = DateTime.UtcNow - createdAt;
        if (diff.TotalMinutes < 1) return "Teď";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} h";
        return createdAt.ToString("dd.MM.yyyy");
    }

    public void Dispose()
    {
        _pollingTimer?.Dispose();
    }
}
