@using Microsoft.Extensions.Localization
@inject IStringLocalizer<GuestConvertModal> L

@if (IsOpen)
{
    <div class="modal-overlay" @onclick="OnClose">
        <div class="modal-content" @onclick:stopPropagation data-testid="guest-convert-modal">
            <div class="modal-header">
                <TmIcon Name="@IconNames.Trophy" Class="header-icon" />
                <h3>@L["Title"]</h3>
                <button class="btn-close" @onclick="OnClose">×</button>
            </div>
            <div class="modal-body">
                <p class="description">@L["Description"]</p>
                <div class="results-card">
                    <h4>@L["YourResults"]</h4>
                    <div class="result-stat">
                        <TmIcon Name="@IconNames.Check" Class="stat-icon success" />
                        <span>@string.Format(L["WordsSolved"], WordsSolved)</span>
                    </div>
                    <div class="result-stat highlight">
                        <TmIcon Name="@IconNames.Star" Class="stat-icon warning" />
                        <span>@string.Format(L["TotalXp"], TotalXp)</span>
                    </div>
                </div>
                <TmAlert Severity="AlertSeverity.Info" Class="save-alert">
                    @string.Format(L["SaveProgressDescription"], TotalXp)
                </TmAlert>
            </div>
            <div class="modal-footer">
                <div data-testid="btn-play-again">
                    <TmButton Variant="ButtonVariant.Outline" OnClick="OnPlayAgain">
                        @L["PlayAgain"]
                    </TmButton>
                </div>
                <div data-testid="btn-save-progress">
                    <TmButton Variant="ButtonVariant.Primary" OnClick="OnRegister">
                        @L["SaveProgress"]
                    </TmButton>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public int WordsSolved { get; set; }
    [Parameter] public int TotalXp { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnRegister { get; set; }
    [Parameter] public EventCallback OnPlayAgain { get; set; }
}
